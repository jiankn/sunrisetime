---
/**
 * Base Layout — SunriseTime.co
 * 所有页面共用的 HTML 外壳
 */
interface Props {
  title: string;
  description: string;
  canonical?: string;
  keywords?: string;
  jsonLd?: object[];
  robots?: string;
  ogType?: string;
}

const {
  title,
  description,
  canonical = 'https://sunrisetime.co/',
  keywords = 'sunrise time, sunset time, golden hour, moon phase',
  jsonLd = [],
  robots = 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1',
  ogType = 'website',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="keywords" content={keywords}>
  <meta name="robots" content={robots}>
  <link rel="canonical" href={canonical}>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="apple-touch-icon" href="/logo.png">

  <!-- Open Graph -->
  <meta property="og:type" content={ogType}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={canonical}>
  <meta property="og:site_name" content="SunriseTime">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>

  <!-- Google Fonts: Sora + Manrope -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <!-- Lucide Icons CDN -->
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js" defer></script>

  <!-- Global Styles -->
  <link rel="stylesheet" href="/styles/global.css">

  <!-- JSON-LD Structured Data -->
  {jsonLd.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", "@graph": jsonLd })} />
  )}

  <!--
    Google AdSense Auto Ads
    接入步骤：
    1. 在 AdSense 后台获取你的 ca-pub-XXXXXXXXXXXXXXXX ID
    2. 取消下方注释，替换 data-ad-client 值
    3. Auto Ads 会自动分析页面结构，在最优位置插入广告
    4. 无需手动指定广告位置，Google 算法最大化收益
  -->
  <!-- <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX" crossorigin="anonymous"></script> -->

  <slot name="head" />
</head>
<body>
  <slot />
  <script src="/scripts/main.js" defer></script>
</body>
</html>
