---
import ApiGuideContent from '@components/ApiGuideContent.astro';
import Footer from '@components/Footer.astro';
import Header from '@components/Header.astro';
import { supportEmail, totalCities } from '@data/site';
import Base from '@layouts/Base.astro';
import { buildLanguageSwitcherLinks, localizePath } from '@i18n/config';
import { englishApiGuideCopy } from '@i18n/api-guide-page';
import { buildAlternateLinks, buildBreadcrumbJsonLd } from '@utils/seo';

const pagePath = '/guides/api/';
const pageUrl = `https://sunrisetime.co${pagePath}`;
const alternates = buildAlternateLinks([
  { hrefLang: 'en', path: pagePath },
  { hrefLang: 'x-default', path: pagePath },
]);
const languageLinks = buildLanguageSwitcherLinks(pagePath);

const sampleCitiesUrl = `https://sunrisetime.co/api/v1/cities?query=${englishApiGuideCopy.sampleQueryCity}&limit=3`;
const sampleTimesUrl = `https://sunrisetime.co/api/v1/times?city=${englishApiGuideCopy.sampleCitySlug}&date=2026-03-29`;
const openApiUrl = 'https://sunrisetime.co/api/v1/openapi.json';
const cityLookupCurl = `curl "${sampleCitiesUrl}"`;
const timingCurl = `curl "${sampleTimesUrl}"`;
const jsExample = `const cityLookup = await fetch("https://sunrisetime.co/api/v1/cities?query=${englishApiGuideCopy.sampleQueryCity}&limit=1");\nconst cityResult = await cityLookup.json();\nconst citySlug = cityResult.cities[0]?.slug;\n\nconst timingResponse = await fetch(\`https://sunrisetime.co/api/v1/times?city=\${citySlug}&date=2026-03-29\`\n);\nconst timingData = await timingResponse.json();\n\nconsole.log(timingData.sun.sunrise, timingData.prayerTimes.maghrib);`;
const sampleResponse = `{\n  "meta": {\n    "version": "v1",\n    "endpoint": "/api/v1/times",\n    "cacheTtlSeconds": 900\n  },\n  "city": {\n    "slug": "${englishApiGuideCopy.sampleCitySlug}",\n    "name": "London",\n    "timezone": "Europe/London"\n  },\n  "sun": {\n    "sunrise": "6:44 AM",\n    "sunset": "7:26 PM"\n  },\n  "moon": {\n    "phase": "Waxing Crescent",\n    "illumination": 12\n  },\n  "prayerTimes": {\n    "fajr": "5:10 AM",\n    "maghrib": "7:26 PM"\n  }\n}`;

const jsonLd = [
  {
    "@type": "TechArticle",
    "@id": `${pageUrl}#article`,
    "headline": englishApiGuideCopy.pageTitle,
    "description": englishApiGuideCopy.pageDescription,
    "url": pageUrl,
    "inLanguage": "en",
    "author": {
      "@type": "Organization",
      "name": "SunriseTime",
    },
  },
  buildBreadcrumbJsonLd([
    { name: 'Home', path: '/' },
    { name: 'Guides', path: '/guides/' },
    { name: 'API', path: pagePath },
  ]),
];
---

<Base
  title={englishApiGuideCopy.pageTitle}
  description={englishApiGuideCopy.pageDescription}
  canonical={pageUrl}
  keywords={englishApiGuideCopy.keywords}
  jsonLd={jsonLd}
  lang="en"
  alternates={alternates}
>
  <Header languageLinks={languageLinks} currentLanguage="en" />
  <ApiGuideContent
    copy={englishApiGuideCopy}
    sampleCitiesUrl={sampleCitiesUrl}
    sampleTimesUrl={sampleTimesUrl}
    openApiUrl={openApiUrl}
    cityLookupCurl={cityLookupCurl}
    timingCurl={timingCurl}
    jsExample={jsExample}
    sampleResponse={sampleResponse}
    supportEmail={supportEmail}
  >
    <span slot="subtitle">{englishApiGuideCopy.subtitle(totalCities)}</span>
  </ApiGuideContent>
  <Footer />
</Base>
