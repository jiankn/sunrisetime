---
/**
 * [city].astro — 城市日出日落页（核心 SEO 模板）
 *
 * 路由: /sunrise/new-york/, /sunrise/tokyo/, etc.
 * SSG: getStaticPaths() 从 cities.json 生成
 */
import Base from '@layouts/Base.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import AdUnit from '@components/AdUnit.astro';
import { getCityBySlug, getCityDisplayName, getCityLocationLabel, getCityStaticPaths, getComparisonCities, getNearbyCities } from '@data/site';
import { getSunTimes, getGoldenHour, getDaylightSeries, formatTime, getSunriseDelta, getSunsetDelta, getDaylightChangeDays, getSunEventShiftDays, getAnnualSunExtremes, getSeasonalSunCheckpoints, getLocalYear } from '@utils/sun';
import { getMoonData, getNextMoonEvent } from '@utils/moon';
import { getPrayerTimes, getNextPrayer } from '@utils/prayer-times';
import { buildAlternateLinks, buildBreadcrumbJsonLd } from '@utils/seo';
import { buildLanguageSwitcherLinks, localizePath } from '@i18n/config';
import SunriseQuality from '@components/SunriseQuality.astro';

export function getStaticPaths() {
  return getCityStaticPaths();
}

Astro.response.headers.set('Cache-Control', 'public, max-age=300, s-maxage=3600');

const city = getCityBySlug(Astro.params.city ?? '');

if (!city) {
  return new Response(null, { status: 404, statusText: 'Not found' });
}

const cityLabel = getCityDisplayName(city, { includeAdmin1: Boolean(city.admin1) });
const cityLocationLabel = getCityLocationLabel(city, { includeAdmin1: Boolean(city.admin1) });

function clamp(value: number, min: number, max: number) {
  return Math.min(Math.max(value, min), max);
}

function formatCountdown(ms: number) {
  const totalMinutes = Math.max(1, Math.round(ms / 60000));
  const hours = Math.floor(totalMinutes / 60);
  const minutes = totalMinutes % 60;

  if (hours && minutes) return `${hours}h ${minutes}m`;
  if (hours) return `${hours}h`;
  return `${minutes}m`;
}

function formatMinuteShift(delta: number) {
  if (delta === 0) return 'Same as yesterday';

  const minutes = Math.abs(delta);
  const direction = delta > 0 ? 'later' : 'earlier';

  return `${minutes} min ${direction} than yesterday`;
}

function formatMinuteShiftSentence(delta: number) {
  if (delta === 0) return 'at the same local time as yesterday';

  const minutes = Math.abs(delta);
  const direction = delta > 0 ? 'later' : 'earlier';

  return `${minutes} min ${direction} than yesterday`;
}

function formatDaylightTrend(minutes: number) {
  if (minutes === 0) return 'Holding steady across 7 days';

  const direction = minutes > 0 ? 'longer' : 'shorter';
  return `${Math.abs(minutes)} min ${direction} across 7 days`;
}

function formatRelativeClockShift(delta: number, baseline: string) {
  if (delta === 0) return `Same local time as ${baseline}`;

  const direction = delta > 0 ? 'later' : 'earlier';
  return `${Math.abs(delta)} min ${direction} than ${baseline}`;
}

function formatRelativeDaylight(delta: number, baseline: string) {
  if (delta === 0) return `Same daylight length as ${baseline}`;

  const direction = delta > 0 ? 'longer' : 'shorter';
  return `${Math.abs(delta)} min ${direction} than ${baseline}`;
}

function formatCalendarDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    timeZone: city.timezone,
  });
}

const today = new Date();
const currentYear = getLocalYear(today, city.timezone);
const sun = getSunTimes(today, city.lat, city.lng);
const golden = getGoldenHour(today, city.lat, city.lng);
const moon = getMoonData(today, city.lat, city.lng);
const nextMoonEvent = getNextMoonEvent(today);
const prayers = getPrayerTimes(today, city.lat, city.lng, 'MWL', 'Standard');
const nextPrayer = getNextPrayer(today, city.lat, city.lng, 'MWL', 'Standard');
const sunriseDelta = getSunriseDelta(today, city.lat, city.lng, city.timezone);
const sunsetDelta = getSunsetDelta(today, city.lat, city.lng, city.timezone);
const series = getDaylightSeries(today, 7, city.lat, city.lng);
const daylightTrendMinutes = Math.round((series[series.length - 1].hours - series[0].hours) * 60);
const sunriseDeltaCopy = formatMinuteShift(sunriseDelta);
const sunsetDeltaCopy = formatMinuteShift(sunsetDelta);
const sunriseDeltaSentence = formatMinuteShiftSentence(sunriseDelta);
const sunsetDeltaSentence = formatMinuteShiftSentence(sunsetDelta);
const daylightTrendCopy = formatDaylightTrend(daylightTrendMinutes);
const daylightVs30DaysAgo = -getDaylightChangeDays(today, -30, city.lat, city.lng);
const sunriseVs30DaysAgo = -getSunEventShiftDays(today, -30, city.lat, city.lng, city.timezone, 'sunrise');
const sunsetVs30DaysAgo = -getSunEventShiftDays(today, -30, city.lat, city.lng, city.timezone, 'sunset');
const daylightIn30Days = getDaylightChangeDays(today, 30, city.lat, city.lng);
const sunriseIn30Days = getSunEventShiftDays(today, 30, city.lat, city.lng, city.timezone, 'sunrise');
const sunsetIn30Days = getSunEventShiftDays(today, 30, city.lat, city.lng, city.timezone, 'sunset');
const annualExtremes = getAnnualSunExtremes(currentYear, city.lat, city.lng, city.timezone);
const seasonalCheckpoints = getSeasonalSunCheckpoints(currentYear, city.lat, city.lng);

function getNextSunEvent() {
  if (today < sun.sunrise) {
    return {
      label: 'Sunrise in',
      countdown: formatCountdown(sun.sunrise.getTime() - today.getTime()),
      time: formatTime(sun.sunrise, city.timezone),
      support: `Morning golden hour runs until ${formatTime(golden.morning.end, city.timezone)}.`,
    };
  }

  if (today < sun.sunset) {
    return {
      label: 'Sunset in',
      countdown: formatCountdown(sun.sunset.getTime() - today.getTime()),
      time: formatTime(sun.sunset, city.timezone),
      support: `Evening golden hour begins at ${formatTime(golden.evening.start, city.timezone)}.`,
    };
  }

  const tomorrow = new Date(today);
  tomorrow.setDate(tomorrow.getDate() + 1);
  const tomorrowSun = getSunTimes(tomorrow, city.lat, city.lng);

  return {
    label: 'Tomorrow sunrise',
    countdown: formatCountdown(tomorrowSun.sunrise.getTime() - today.getTime()),
    time: formatTime(tomorrowSun.sunrise, city.timezone),
    support: `Tomorrow brings ${tomorrowSun.daylightFormatted} of daylight.`,
  };
}

const nextSunEvent = getNextSunEvent();
const localDateLabel = today.toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: city.timezone,
});
const localTimeLabel = today.toLocaleTimeString('en-US', {
  hour: 'numeric',
  minute: '2-digit',
  hour12: true,
  timeZone: city.timezone,
});
const lightProgress = clamp(
  ((today.getTime() - sun.dawn.getTime()) / (sun.dusk.getTime() - sun.dawn.getTime())) * 100,
  0,
  100,
);
const lightStatus = today < sun.dawn
  ? 'Night is still in control.'
  : today < sun.sunrise
    ? 'Civil dawn has started.'
    : today < sun.sunset
      ? 'Daylight is active right now.'
      : today < sun.dusk
        ? 'Civil dusk is fading out.'
        : 'Night has taken over again.';
const daysUntilMoonEvent = Math.max(1, Math.ceil((nextMoonEvent.date.getTime() - today.getTime()) / 86400000));

// Nearby cities for internal linking (same continent, exclude self)
const nearbyCities = getNearbyCities(city, 6);
const otherCities = getComparisonCities(city, 4);

const pageTitle = `Sunrise & Sunset Times in ${cityLabel} Today — SunriseTime`;
const pageDesc = `Today's sunrise in ${cityLabel} is at ${formatTime(sun.sunrise, city.timezone)}, sunset at ${formatTime(sun.sunset, city.timezone)}. ${sun.daylightFormatted} of daylight. Golden hour, moon phase, and prayer times included.`;
const pagePath = `/sunrise/${city.slug}/`;
const pageUrl = `https://sunrisetime.co${pagePath}`;
const liveCityConfig = {
  kind: 'sun',
  citySlug: city.slug,
  timezone: city.timezone,
  locale: 'en-US',
  duration: {
    hourLabel: 'h',
    minuteLabel: 'm',
    numberUnitSeparator: '',
    partSeparator: ' ',
  },
  leadTemplate: 'Local time is {{localTime}}. Sunrise in ' + city.name + ' is at {{sunrise}} and sunset is at {{sunset}}. Use the quick paths below to jump straight to photography, moon, or prayer details.',
  nextTimeTemplate: '{{nextTime}} local time',
  events: {
    sunrise: {
      label: 'Sunrise in',
      supportTemplate: 'Morning golden hour runs until {{morningEnd}}.',
    },
    sunset: {
      label: 'Sunset in',
      supportTemplate: 'Evening golden hour begins at {{eveningStart}}.',
    },
    tomorrowSunrise: {
      label: 'Tomorrow sunrise',
      supportTemplate: 'Tomorrow brings {{daylight}} of daylight.',
    },
  },
  lightStatusLabels: {
    beforeDawn: 'Night is still in control.',
    beforeSunrise: 'Civil dawn has started.',
    beforeSunset: 'Daylight is active right now.',
    beforeDusk: 'Civil dusk is fading out.',
    afterDusk: 'Night has taken over again.',
  },
};
const alternates = buildAlternateLinks([
  { hrefLang: 'en', path: pagePath },
  { hrefLang: 'es', path: localizePath('es', pagePath) },
  { hrefLang: 'x-default', path: pagePath },
]);
const languageLinks = buildLanguageSwitcherLinks(pagePath);
const UrlPrayerTimes = `/prayer-times/${city.slug}/`;
const breadcrumbItems = [
  { name: 'Home', path: '/' },
  { name: 'Cities', path: '/cities/' },
  { name: city.name, path: `/sunrise/${city.slug}/` },
];

const jsonLd = [
  {
    "@type": "WebPage",
    "@id": `${pageUrl}#webpage`,
    "name": pageTitle,
    "description": pageDesc,
    "url": pageUrl,
    "isPartOf": {
      "@id": "https://sunrisetime.co/#website"
    }
  },
  buildBreadcrumbJsonLd(breadcrumbItems),
  {
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    "mainEntity": [
      {
        "@type": "Question",
        "name": `What time is sunrise in ${cityLabel} today?`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `Sunrise in ${cityLabel} today is at ${formatTime(sun.sunrise, city.timezone)}.`
        }
      },
      {
        "@type": "Question",
        "name": `What time is sunset in ${cityLabel} today?`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `Sunset in ${cityLabel} today is at ${formatTime(sun.sunset, city.timezone)}.`
        }
      }
    ]
  }
];
---

<Base
  title={pageTitle}
  description={pageDesc}
  canonical={pageUrl}
  keywords={`sunrise ${cityLabel}, sunset ${cityLabel}, golden hour ${cityLabel}, ${cityLabel} sun times`}
  jsonLd={jsonLd}
  lang="en"
  alternates={alternates}
>
  <Header languageLinks={languageLinks} currentLanguage="en" />

  <main class="city-page" data-live-city-root data-live-config-id="cityLiveConfig">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <i data-lucide="chevron-right" class="icon-xs"></i>
        <a href="/cities/">Cities</a>
        <i data-lucide="chevron-right" class="icon-xs"></i>
        <span>{city.name}</span>
      </nav>

      <section class="city-snapshot glass-card-lg">
        <div class="city-snapshot-copy">
          <span class="city-kicker">Local light in {city.name}</span>
          <h1>Sunrise & Sunset in <span class="gradient-text">{city.name}</span></h1>
          <p class="city-lead" data-live-lead>
            Local time is {localTimeLabel}. Sunrise in {city.name} is at {formatTime(sun.sunrise, city.timezone)} and sunset is at {formatTime(sun.sunset, city.timezone)}.
            Use the quick paths below to jump straight to photography, moon, or prayer details.
          </p>

          <div class="city-chip-row">
            <span class="city-chip city-country-badge">{cityLocationLabel}</span>
            <span class="city-chip">{city.timezone}</span>
            <span class="city-chip">{sun.daylightFormatted} daylight</span>
          </div>

          <div class="city-action-row">
            <a href="/cities/" class="btn-primary">
              <i data-lucide="search" class="icon-xs"></i>
              Search another city
            </a>
            <a href="#photography" class="btn-secondary">
              <i data-lucide="camera" class="icon-xs"></i>
              See golden hour
            </a>
            <a href={UrlPrayerTimes} class="btn-secondary">
              <i data-lucide="clock" class="icon-xs"></i>
              Prayer times
            </a>
          </div>
        </div>

        <div class="city-snapshot-panel">
          <div class="city-next-event glass-card">
            <span class="city-next-label" data-live-next-label>{nextSunEvent.label}</span>
            <strong data-live-next-countdown>{nextSunEvent.countdown}</strong>
            <span class="city-next-time" data-live-next-time>{nextSunEvent.time} local time</span>
            <p data-live-next-support>{nextSunEvent.support}</p>
          </div>

          <div class="city-light-track glass-card">
            <div class="city-track-head">
              <span>Dawn {formatTime(sun.dawn, city.timezone)}</span>
              <strong data-live-light-status>{lightStatus}</strong>
              <span>Dusk {formatTime(sun.dusk, city.timezone)}</span>
            </div>
            <div class="city-track-bar">
              <span class="city-track-fill" data-live-light-fill style={`width:${lightProgress}%`}></span>
              <span class="city-track-marker" data-live-light-marker style={`left:${lightProgress}%`}></span>
            </div>
            <div class="city-track-points">
              <span>Sunrise {formatTime(sun.sunrise, city.timezone)}</span>
              <span>Solar noon {formatTime(sun.solarNoon, city.timezone)}</span>
              <span>Sunset {formatTime(sun.sunset, city.timezone)}</span>
            </div>
          </div>
          
          <SunriseQuality lat={city.lat} lng={city.lng} timezone={city.timezone} />

          <div class="city-snapshot-metrics">
            <div class="city-metric-card glass-card accent-sunrise">
              <span class="city-metric-visual" aria-hidden="true"></span>
              <span class="city-metric-label">Sunrise</span>
              <strong class="city-metric-value">{formatTime(sun.sunrise, city.timezone)}</strong>
              <small class="city-metric-note">{sunriseDeltaCopy}</small>
            </div>
            <div class="city-metric-card glass-card accent-sunset">
              <span class="city-metric-visual" aria-hidden="true"></span>
              <span class="city-metric-label">Sunset</span>
              <strong class="city-metric-value">{formatTime(sun.sunset, city.timezone)}</strong>
              <small class="city-metric-note">{sunsetDeltaCopy}</small>
            </div>
            <div class="city-metric-card glass-card accent-daylight">
              <span class="city-metric-visual" aria-hidden="true"></span>
              <span class="city-metric-label">Daylight</span>
              <strong class="city-metric-value">{sun.daylightFormatted}</strong>
              <small class="city-metric-note">{daylightTrendCopy}</small>
            </div>
            <div class="city-metric-card glass-card accent-moon">
              <span class="city-metric-visual" aria-hidden="true"></span>
              <span class="city-metric-label">Moon</span>
              <strong class="city-metric-value">{moon.phaseName}</strong>
              <small class="city-metric-note">{moon.illumination}% illumination tonight</small>
            </div>
          </div>
        </div>
      </section>

      <section class="city-highlight-grid" aria-label="Quick paths">
        <a href="#photography" class="city-highlight-card glass-card">
          <span class="city-highlight-label">Photography</span>
          <strong>Golden hour windows</strong>
          <p>Morning {formatTime(golden.morning.start, city.timezone)} to {formatTime(golden.morning.end, city.timezone)} · Evening starts {formatTime(golden.evening.start, city.timezone)}</p>
        </a>
        <a href="#moon" class="city-highlight-card glass-card">
          <span class="city-highlight-label">Moon</span>
          <strong>{nextMoonEvent.type} in {daysUntilMoonEvent} day{daysUntilMoonEvent !== 1 ? 's' : ''}</strong>
          <p>{moon.phaseName} now with {moon.illumination}% illumination.</p>
        </a>
        <a href="#prayer" class="city-highlight-card glass-card">
          <span class="city-highlight-label">Prayer</span>
          <strong>{nextPrayer.name} at {formatTime(nextPrayer.time, city.timezone)}</strong>
          <p>Full schedule stays below when you need it.</p>
        </a>
      </section>

      <section class="detail-section" id="photography" aria-label="Photography windows">
        <div class="detail-section-head">
          <h2><i data-lucide="camera" class="icon-md"></i> Photography Windows in {city.name}</h2>
          <p>Lead with the moments that actually change your outdoor plan: golden hour, twilight, and whether daylight is getting longer or shorter this week.</p>
        </div>

        <div class="detail-grid">
          <div class="detail-card glass-card">
            <h3>Morning Golden Hour</h3>
            <div class="detail-time">
              <span class="detail-time-value">{formatTime(golden.morning.start, city.timezone)}</span>
              <i data-lucide="arrow-right" class="icon-sm"></i>
              <span class="detail-time-value">{formatTime(golden.morning.end, city.timezone)}</span>
            </div>
            <span class="detail-duration">{golden.morning.durationMin} minutes</span>
          </div>
          <div class="detail-card glass-card">
            <h3>Evening Golden Hour</h3>
            <div class="detail-time">
              <span class="detail-time-value">{formatTime(golden.evening.start, city.timezone)}</span>
              <i data-lucide="arrow-right" class="icon-sm"></i>
              <span class="detail-time-value">{formatTime(golden.evening.end, city.timezone)}</span>
            </div>
            <span class="detail-duration">{golden.evening.durationMin} minutes</span>
          </div>
        </div>

        <div class="city-secondary-grid">
          <div class="twilight-table glass-card">
            <table>
              <thead>
                <tr><th>Phase</th><th>Dawn</th><th>Dusk</th></tr>
              </thead>
              <tbody>
                <tr>
                  <td>Civil Twilight</td>
                  <td>{formatTime(sun.dawn, city.timezone)}</td>
                  <td>{formatTime(sun.dusk, city.timezone)}</td>
                </tr>
                <tr>
                  <td>Nautical Twilight</td>
                  <td>{formatTime(sun.nauticalDawn, city.timezone)}</td>
                  <td>{formatTime(sun.nauticalDusk, city.timezone)}</td>
                </tr>
                <tr>
                  <td>Astronomical Twilight</td>
                  <td>{formatTime(sun.nightEnd, city.timezone)}</td>
                  <td>{formatTime(sun.night, city.timezone)}</td>
                </tr>
              </tbody>
            </table>
          </div>

          <div class="daylight-chart glass-card">
            <div class="demo-chart-title">Daylight Trend — 7 Day View</div>
            <div class="chart-bars-static">
              {series.map((s, i) => {
                const pct = Math.round((s.hours / 16) * 100);
                const dayName = s.date.toLocaleDateString('en-US', { weekday: 'short', timeZone: city.timezone });
                return (
                  <div class={`chart-col ${i === 0 ? 'active' : ''}`}>
                    <span class="chart-val">{s.hours.toFixed(1)}h</span>
                    <div class="chart-fill" style={`height:${pct}%`}></div>
                    <span class="chart-day">{dayName}</span>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      </section>

      <AdUnit id="ad-city-mid" />

      <section class="detail-section" id="moon" aria-label="Moon data">
        <div class="detail-section-head">
          <h2><i data-lucide="moon" class="icon-md"></i> Moon Data for {city.name}</h2>
          <p>Useful when your plan extends past sunset or when you want to know whether moonlight will help or compete with the shot.</p>
        </div>

        <div class="detail-grid">
          <div class="detail-card glass-card">
            <h3>Moon Phase</h3>
            <div class="moon-display">
              <div>
                <span class="detail-time-value">{moon.phaseName}</span>
                <span class="detail-duration">{moon.illumination}% illumination</span>
              </div>
            </div>
          </div>
          <div class="detail-card glass-card">
            <h3>Moonrise & Moonset</h3>
            <div class="detail-time">
              <div>
                <span class="data-label">Rise</span>
                <span class="detail-time-value">{moon.rise ? formatTime(moon.rise, city.timezone) : '—'}</span>
              </div>
              <div>
                <span class="data-label">Set</span>
                <span class="detail-time-value">{moon.set ? formatTime(moon.set, city.timezone) : '—'}</span>
              </div>
            </div>
            <span class="detail-duration">{nextMoonEvent.type} arrives in {daysUntilMoonEvent} day{daysUntilMoonEvent !== 1 ? 's' : ''}.</span>
          </div>
        </div>
      </section>

      <section class="detail-section" id="prayer" aria-label="Prayer times">
        <div class="detail-section-head">
          <h2><i data-lucide="clock" class="icon-md"></i> Prayer Times in {city.name}</h2>
          <p>The full schedule is available when you need it, while the page keeps the main sunrise and sunset answer easy to scan for everyone else.</p>
        </div>

        <div class="prayer-callout glass-card">
          <span class="prayer-callout-label">Next prayer</span>
          <strong>{nextPrayer.name}</strong>
          <span>{formatTime(nextPrayer.time, city.timezone)}</span>
        </div>

        <div class="prayer-grid">
          {[
            { name: 'Fajr', time: prayers.fajr, icon: 'cloud-moon' },
            { name: 'Sunrise', time: prayers.sunrise, icon: 'sunrise' },
            { name: 'Dhuhr', time: prayers.dhuhr, icon: 'sun' },
            { name: 'Asr', time: prayers.asr, icon: 'cloud-sun' },
            { name: 'Maghrib', time: prayers.maghrib, icon: 'sunset' },
            { name: 'Isha', time: prayers.isha, icon: 'moon' },
          ].map(p => (
            <div class="prayer-card glass-card">
              <i data-lucide={p.icon} class="icon-md"></i>
              <span class="prayer-name">{p.name}</span>
              <span class="prayer-time">{formatTime(p.time, city.timezone)}</span>
            </div>
          ))}
        </div>
        <p class="prayer-note">
          Calculated using Muslim World League (MWL) method. Standard (Shafi&apos;i) juristic method for Asr.
        </p>
        <div class="prayer-sun-cta" style="margin-top:1rem;">
          <a href={UrlPrayerTimes} class="btn-primary">
            <i data-lucide="arrow-right" class="icon-xs"></i>
            Full prayer times page for {city.name}
          </a>
        </div>
      </section>

      <AdUnit id="ad-city-bottom" />

      <section class="detail-section seo-content" aria-label="About sunrise and sunset">
        <h2><i data-lucide="info" class="icon-md"></i> About Sunrise & Sunset in {city.name}</h2>
        <div class="seo-text glass-card">
          <p>
            Today in {city.name}, the sun rises at {formatTime(sun.sunrise, city.timezone)} and sets at {formatTime(sun.sunset, city.timezone)}, providing {sun.daylightFormatted} of daylight. Solar noon lands at {formatTime(sun.solarNoon, city.timezone)}, when the sun reaches its highest point in the sky. Civil twilight begins at {formatTime(sun.dawn, city.timezone)} and ends at {formatTime(sun.dusk, city.timezone)}, extending usable outdoor light beyond sunrise and sunset.
          </p>

          <h3>How Sunrise and Sunset Times Are Calculated</h3>
          <p>
            SunriseTime uses the NOAA Solar Calculator algorithm to compute sunrise and sunset times with precision within one minute. The calculation accounts for {city.name}&apos;s geographic coordinates (latitude {city.lat.toFixed(4)}°, longitude {city.lng.toFixed(4)}°), atmospheric refraction, and the sun&apos;s apparent diameter. All times are displayed in the local timezone ({city.timezone}) and updated daily.
          </p>

          <h3>Golden Hour Photography in {city.name}</h3>
          <p>
            The morning golden hour in {city.name} runs from {formatTime(golden.morning.start, city.timezone)} to {formatTime(golden.morning.end, city.timezone)} ({golden.morning.durationMin} minutes), while the evening golden hour spans {formatTime(golden.evening.start, city.timezone)} to {formatTime(golden.evening.end, city.timezone)} ({golden.evening.durationMin} minutes). During golden hour, sunlight travels through more atmosphere, producing warm tones ideal for photography and filmmaking.
          </p>

          <h3>Daylight Trends and Seasonal Changes</h3>
          <p>
            Daylight duration in {city.name} changes throughout the year based on its latitude of {city.lat.toFixed(2)}°. The 7-day forecast above shows how daylight hours are currently trending. Compared to yesterday, sunrise is {sunriseDeltaSentence} and sunset is {sunsetDeltaSentence}, reflecting the gradual seasonal transition.
          </p>

          <h3>Moon Phase and Lunar Data</h3>
          <p>
            The current moon phase in {city.name} is {moon.phaseName} with {moon.illumination}% illumination. {moon.rise ? `Moonrise occurs at ${formatTime(moon.rise, city.timezone)}` : 'The moon does not rise today'}{moon.set ? ` and moonset at ${formatTime(moon.set, city.timezone)}` : ''}. Lunar data is useful for astronomers, photographers planning night shoots, and anyone interested in tidal patterns.
          </p>

          <h3>Prayer Times Calculation Method</h3>
          <p>
            Prayer times for {city.name} are calculated using the Muslim World League (MWL) convention, which sets Fajr at 18° below the horizon and Isha at 17°. The Asr time follows the Standard (Shafi&apos;i) juristic method, where the shadow length equals the object height plus the shadow at solar noon.
          </p>
        </div>
      </section>

      <section class="detail-section" aria-label="30-day light outlook">
        <div class="detail-section-head">
          <h2><i data-lucide="calendar-range" class="icon-md"></i> 30-Day Light Outlook</h2>
          <p>These changes make the page useful beyond the one-off “what time is sunrise today?” query.</p>
        </div>

        <div class="detail-grid">
          <div class="detail-card glass-card">
            <h3>Compared with 30 days ago</h3>
            <div class="outlook-stat">
              <span class="outlook-label">Daylight</span>
              <span class="outlook-val">{formatRelativeDaylight(daylightVs30DaysAgo, '30 days ago')}</span>
            </div>
            <div class="outlook-stat">
              <span class="outlook-label">Sunrise & Sunset</span>
              <span class="outlook-val">{formatRelativeClockShift(sunriseVs30DaysAgo, '30 days ago')} · {formatRelativeClockShift(sunsetVs30DaysAgo, '30 days ago')}</span>
            </div>
            <span class="detail-duration" style="margin-top: 0.5rem; display:block;">This helps explain whether mornings are opening up or tightening right now.</span>
          </div>

          <div class="detail-card glass-card">
            <h3>Expected 30 days from now</h3>
            <div class="outlook-stat">
              <span class="outlook-label">Daylight</span>
              <span class="outlook-val">{formatRelativeDaylight(daylightIn30Days, 'today')}</span>
            </div>
            <div class="outlook-stat">
              <span class="outlook-label">Sunrise & Sunset</span>
              <span class="outlook-val">{formatRelativeClockShift(sunriseIn30Days, 'today')} · {formatRelativeClockShift(sunsetIn30Days, 'today')}</span>
            </div>
            <span class="detail-duration" style="margin-top: 0.5rem; display:block;">A quick way to see how much the local light schedule will move over the next month.</span>
          </div>
        </div>
      </section>

      <section class="detail-section" aria-label="annual light extremes">
        <div class="detail-section-head">
          <h2><i data-lucide="trophy" class="icon-md"></i> {currentYear} Annual Light Extremes</h2>
          <p>This section answers the next useful question after today: when are the real yearly limits for local light?</p>
        </div>

        <div class="detail-grid">
          <div class="detail-card glass-card">
            <h3>Sunrise extremes</h3>
            <div class="detail-time">
              <div>
                <span class="data-label">Earliest sunrise</span>
                <span class="detail-time-value">{formatTime(annualExtremes.earliestSunrise.time, city.timezone)}</span>
              </div>
              <div>
                <span class="data-label">Latest sunrise</span>
                <span class="detail-time-value">{formatTime(annualExtremes.latestSunrise.time, city.timezone)}</span>
              </div>
            </div>
            <span class="detail-duration">{formatCalendarDate(annualExtremes.earliestSunrise.date)} · {formatCalendarDate(annualExtremes.latestSunrise.date)}</span>
          </div>

          <div class="detail-card glass-card">
            <h3>Sunset extremes</h3>
            <div class="detail-time">
              <div>
                <span class="data-label">Earliest sunset</span>
                <span class="detail-time-value">{formatTime(annualExtremes.earliestSunset.time, city.timezone)}</span>
              </div>
              <div>
                <span class="data-label">Latest sunset</span>
                <span class="detail-time-value">{formatTime(annualExtremes.latestSunset.time, city.timezone)}</span>
              </div>
            </div>
            <span class="detail-duration">{formatCalendarDate(annualExtremes.earliestSunset.date)} · {formatCalendarDate(annualExtremes.latestSunset.date)}</span>
          </div>
        </div>

        <div class="detail-grid">
          <div class="detail-card glass-card">
            <h3>Longest day</h3>
            <div class="detail-time">
              <div>
                <span class="data-label">Daylight</span>
                <span class="detail-time-value">{annualExtremes.longestDay.daylightFormatted}</span>
              </div>
              <div>
                <span class="data-label">Date</span>
                <span class="detail-time-value">{formatCalendarDate(annualExtremes.longestDay.date)}</span>
              </div>
            </div>
            <span class="detail-duration">The widest daylight window of the year in {city.name}.</span>
          </div>

          <div class="detail-card glass-card">
            <h3>Shortest day</h3>
            <div class="detail-time">
              <div>
                <span class="data-label">Daylight</span>
                <span class="detail-time-value">{annualExtremes.shortestDay.daylightFormatted}</span>
              </div>
              <div>
                <span class="data-label">Date</span>
                <span class="detail-time-value">{formatCalendarDate(annualExtremes.shortestDay.date)}</span>
              </div>
            </div>
            <span class="detail-duration">The narrowest daylight window of the year in {city.name}.</span>
          </div>
        </div>
      </section>

      <section class="detail-section" aria-label="seasonal daylight checkpoints">
        <div class="detail-section-head">
          <h2><i data-lucide="trees" class="icon-md"></i> Seasonal Daylight Checkpoints</h2>
          <p>These four checkpoints make the year easier to scan than a raw calendar of 365 daily values.</p>
        </div>

        <div class="glass-card">
          <table>
            <thead>
              <tr>
                <th>Checkpoint</th>
                <th>Date</th>
                <th>Sunrise</th>
                <th>Sunset</th>
                <th>Daylight</th>
              </tr>
            </thead>
            <tbody>
              {seasonalCheckpoints.map((checkpoint) => (
                <tr>
                  <td>{checkpoint.label}</td>
                  <td>{formatCalendarDate(checkpoint.date)}</td>
                  <td>{formatTime(checkpoint.sunrise, city.timezone)}</td>
                  <td>{formatTime(checkpoint.sunset, city.timezone)}</td>
                  <td>{checkpoint.daylightFormatted}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="detail-section" id="nearby" aria-label="Nearby cities">
        <div class="detail-section-head">
          <h2><i data-lucide="map-pin" class="icon-md"></i> Sunrise Times in Nearby Cities</h2>
          <p>Once you have the answer for this city, the next most useful action is usually comparing it with a nearby or destination city.</p>
        </div>

        <div class="nearby-grid">
          {nearbyCities.map(c => (
            <a href={`/sunrise/${c.slug}/`} class="nearby-card glass-card">
              <span class="nearby-name">{c.name}</span>
              <span class="nearby-country">{getCityLocationLabel(c, { includeAdmin1: Boolean(c.admin1) })}</span>
            </a>
          ))}
        </div>
        {otherCities.length > 0 && (
          <>
            <h3 class="other-cities-title">More Cities To Compare</h3>
            <div class="nearby-grid">
              {otherCities.map(c => (
                <a href={`/sunrise/${c.slug}/`} class="nearby-card glass-card">
                  <span class="nearby-name">{c.name}</span>
                  <span class="nearby-country">{getCityLocationLabel(c, { includeAdmin1: Boolean(c.admin1) })}</span>
                </a>
              ))}
            </div>
          </>
        )}
        <div class="cities-cta" style="margin-top:2rem;">
          <a href="/cities/" class="btn-secondary">
            <i data-lucide="globe" class="icon-xs"></i>
            View All Cities
          </a>
        </div>
      </section>
    </div>
  </main>

  <Footer />
  <script type="application/json" id="cityLiveConfig" set:html={JSON.stringify(liveCityConfig)} />
</Base>

