---
/**
 * Cities Hub — /cities/
 * 按区域分组的城市索引页，带客户端搜索过滤
 */
import Base from '@layouts/Base.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { getCityLocationLabel, getCitySearchText, regionHubs, totalCities } from '@data/site';
import { buildBreadcrumbJsonLd } from '@utils/seo';
import { buildLanguageSwitcherLinks, localizePath } from '@i18n/config';
import { buildAlternateLinks } from '@utils/seo';

const pageUrl = 'https://sunrisetime.co/cities/';
const pagePath = '/cities/';
const alternates = buildAlternateLinks([
  { hrefLang: 'en', path: pagePath },
  { hrefLang: 'es', path: localizePath('es', pagePath) },
  { hrefLang: 'x-default', path: pagePath },
]);
const languageLinks = buildLanguageSwitcherLinks(pagePath);

const jsonLd = [
  {
    "@type": "CollectionPage",
    "@id": `${pageUrl}#webpage`,
    "name": "Sunrise & Sunset Times for All Cities",
    "description": `Browse sunrise and sunset times for ${totalCities} cities worldwide. Organized by region with real-time sun, moon, and prayer time data.`,
    "url": pageUrl,
    "isPartOf": {
      "@id": "https://sunrisetime.co/#website"
    }
  },
  buildBreadcrumbJsonLd([
    { name: 'Home', path: '/' },
    { name: 'Cities', path: '/cities/' },
  ]),
];
---

<Base
  title={`Sunrise & Sunset Times for ${totalCities} Cities Worldwide — SunriseTime`}
  description={`Browse sunrise and sunset times for ${totalCities} cities worldwide. Organized by region with golden hour, moon phase, and prayer time data.`}
  canonical={pageUrl}
  keywords="sunrise times by city, sunset times worldwide, city sun data, golden hour cities"
  jsonLd={jsonLd}
  lang="en"
  alternates={alternates}
>
  <Header languageLinks={languageLinks} currentLanguage="en" />

  <main class="cities-hub">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <i data-lucide="chevron-right" class="icon-xs"></i>
        <span>Cities</span>
      </nav>

      <header class="cities-hub-header">
        <h1>Sunrise & Sunset Times for <span class="gradient-text">{totalCities} Cities</span> Worldwide</h1>
        <p>Explore sunrise, sunset, golden hour, moon phase, and prayer time data for cities across each regional hub.</p>
        <div class="hub-search">
          <i data-lucide="search" class="icon-sm" style="color:var(--text-tertiary);flex-shrink:0;"></i>
          <input type="text" id="hubCitySearch" placeholder="Search cities..." autocomplete="off" />
        </div>
      </header>

      {regionHubs.map(group => (
        <section class="continent-section" data-continent={group.slug}>
          <h2>
            <i data-lucide="globe" class="icon-md"></i>
            <a href={group.path}>{group.name}</a>
          </h2>
          <div class="hub-city-grid">
            {group.cities.map(city => (
              <a
                href={`/sunrise/${city.slug}/`}
                class="hub-city-card glass-card"
                data-city-search={getCitySearchText(city).toLowerCase()}
              >
                <span class="hub-city-name">{city.name}</span>
                <span class="hub-city-country">{getCityLocationLabel(city)}</span>
              </a>
            ))}
          </div>
          <div class="cities-cta" style="text-align:left; margin-top:1rem;">
            <a href={group.path} class="btn-secondary-sm">Open {group.name} hub</a>
          </div>
        </section>
      ))}
    </div>
  </main>

  <Footer />
</Base>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const input = document.getElementById('hubCitySearch');
    if (!input) return;

    input.addEventListener('input', (e) => {
      const query = (e.target as HTMLInputElement).value.toLowerCase().trim();
      const cards = document.querySelectorAll<HTMLElement>('.hub-city-card');
      const sections = document.querySelectorAll<HTMLElement>('.continent-section');

      cards.forEach(card => {
        const name = card.dataset.citySearch || '';
        card.style.display = name.includes(query) ? '' : 'none';
      });

      // Hide empty continent sections
      sections.forEach(section => {
        const visible = section.querySelectorAll<HTMLElement>('.hub-city-card:not([style*="display: none"])');
        section.style.display = visible.length > 0 ? '' : 'none';
      });
    });
  });
</script>
