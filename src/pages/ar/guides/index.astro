---
import Base from '@layouts/Base.astro';
import ArabicHeader from '@components/ArabicHeader.astro';
import ArabicFooter from '@components/ArabicFooter.astro';
import { regionHubs, useCaseHubs } from '@data/site';
import { getArabicGuideContent, getArabicRegionName } from '@i18n/arabic';
import { buildLanguageSwitcherLinks, localizePath } from '@i18n/config';
import { buildAlternateLinks, buildBreadcrumbJsonLd } from '@utils/seo';

const pagePath = '/guides/';
const arabicPath = localizePath('ar', pagePath);
const pageUrl = `https://sunrisetime.co${arabicPath}`;
const alternates = buildAlternateLinks([
  { hrefLang: 'en', path: pagePath },
  { hrefLang: 'es', path: localizePath('es', pagePath) },
  { hrefLang: 'ar', path: arabicPath },
  { hrefLang: 'x-default', path: pagePath },
]);
const languageLinks = buildLanguageSwitcherLinks(pagePath);

const jsonLd = [
  {
    "@type": "CollectionPage",
    "@id": `${pageUrl}#webpage`,
    "name": "أدلة SunriseTime",
    "description": "أدلة عربية عن الساعة الذهبية ومرحلة القمر ومواقيت الصلاة وطول النهار.",
    "url": pageUrl,
    "inLanguage": "ar",
    "isPartOf": {
      "@id": "https://sunrisetime.co/ar/#website"
    }
  },
  buildBreadcrumbJsonLd([
    { name: 'الرئيسية', path: '/ar/' },
    { name: 'الأدلة', path: arabicPath },
  ]),
];
---

<Base
  title="أدلة التخطيط - SunriseTime العربية"
  description="راجع الأدلة العربية في SunriseTime للساعة الذهبية ومرحلة القمر ومواقيت الصلاة وطول النهار."
  canonical={pageUrl}
  keywords="دليل الساعة الذهبية, دليل القمر, دليل مواقيت الصلاة"
  jsonLd={jsonLd}
  lang="ar"
  dir="rtl"
  alternates={alternates}
>
  <ArabicHeader languageLinks={languageLinks} currentLanguage="ar" />

  <main class="resource-page">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/ar/">الرئيسية</a>
        <i data-lucide="chevron-right" class="icon-xs"></i>
        <span>الأدلة</span>
      </nav>

      <header class="resource-header">
        <span class="section-badge">
          <i data-lucide="compass" class="icon-xs"></i>
          الأدلة
        </span>
        <h1>استخدم الأدلة عندما يكون السؤال أكبر من مدينة واحدة.</h1>
        <p class="resource-subtitle">تربط الأدلة بين نية البحث العامة والجواب المحلي. ابدأ هنا إذا كنت تحتاج أولًا إلى اختيار الموضوع الصحيح ثم الانتقال إلى المدينة المناسبة.</p>
      </header>

      <section class="resource-link-grid">
        {useCaseHubs.map((hub) => {
          const content = getArabicGuideContent(hub);
          return (
            <a href={`/ar/guides/${hub.slug}/`} class="resource-link-card resource-link-card-rich glass-card">
              <strong>{content.name}</strong>
              <span>{content.description}</span>
            </a>
          );
        })}
      </section>

      <section class="resource-section">
        <div class="detail-section-head">
          <h2>ادمج الأدلة مع المراكز الإقليمية</h2>
          <p>تقوى النية الموضوعية عندما يستطيع المستخدم مقارنة عدة مدن مرتبطة بدون إعادة البحث من الصفر.</p>
        </div>
        <div class="resource-link-grid">
          {regionHubs.map((region) => (
            <a href={`/ar/cities/${region.slug}/`} class="resource-link-card glass-card">
              <strong>{getArabicRegionName(region.slug, region.name)}</strong>
              <span>{region.cityCount} مدينة مفهرسة</span>
            </a>
          ))}
        </div>
      </section>
    </div>
  </main>

  <ArabicFooter />
</Base>
