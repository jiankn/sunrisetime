---
import Base from '@layouts/Base.astro';
import ChineseHeader from '@components/ChineseHeader.astro';
import ChineseFooter from '@components/ChineseFooter.astro';
import { getCityBySlug, getCityStaticPaths, getComparisonCities, getNearbyCities } from '@data/site';
import {
  chineseLocale,
  formatChineseDuration,
  getChineseCityDisplayName,
  getChineseCityLocationLabel,
  getChineseCityName,
  getChinesePrayerName,
  getChineseTimezoneLabel,
} from '@i18n/chinese';
import { buildLanguageSwitcherLinks, localizePath } from '@i18n/config';
import { getSunTimes, formatTime, getClockTimeDelta, getDaylightChangeDays, getLocalYear } from '@utils/sun';
import { getAnnualPrayerExtremes, getNextPrayer, getPrayerSeasonalCheckpoints, getPrayerTimes } from '@utils/prayer-times';
import { buildAlternateLinks, buildBreadcrumbJsonLd } from '@utils/seo';

export function getStaticPaths() {
  return getCityStaticPaths();
}

Astro.response.headers.set('Cache-Control', 'public, max-age=300, s-maxage=3600');

const city = getCityBySlug(Astro.params.city ?? '');

if (!city) {
  return new Response(null, { status: 404, statusText: 'Not found' });
}

function formatCountdown(ms: number) {
  const totalMinutes = Math.max(1, Math.round(ms / 60000));
  const hours = Math.floor(totalMinutes / 60);
  const minutes = totalMinutes % 60;
  if (hours && minutes) return `${hours}小时${minutes}分钟`;
  if (hours) return `${hours}小时`;
  return `${minutes}分钟`;
}

function formatRelativeClockShift(delta: number, baseline: string) {
  if (delta === 0) return `与${baseline}相同`;
  return delta > 0 ? `比${baseline}晚 ${Math.abs(delta)} 分钟` : `比${baseline}早 ${Math.abs(delta)} 分钟`;
}

function formatRelativeDaylight(delta: number, baseline: string) {
  if (delta === 0) return `与${baseline}相同`;
  return delta > 0 ? `比${baseline}长 ${Math.abs(delta)} 分钟` : `比${baseline}短 ${Math.abs(delta)} 分钟`;
}

function formatCalendarDate(date: Date) {
  return date.toLocaleDateString(chineseLocale, {
    month: 'long',
    day: 'numeric',
    timeZone: city.timezone,
  });
}

const today = new Date();
const cityName = getChineseCityName(city);
const cityDisplayName = getChineseCityDisplayName(city);
const locationLabel = getChineseCityLocationLabel(city);
const timezoneLabel = getChineseTimezoneLabel(city.timezone, today);
const sun = getSunTimes(today, city.lat, city.lng);
const prayers = getPrayerTimes(today, city.lat, city.lng, 'MWL', 'Standard');
const nextPrayer = getNextPrayer(today, city.lat, city.lng, 'MWL', 'Standard');
const thirtyDaysAgo = new Date(today);
thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);
const thirtyDaysLater = new Date(today);
thirtyDaysLater.setDate(thirtyDaysLater.getDate() + 30);
const pastPrayers = getPrayerTimes(thirtyDaysAgo, city.lat, city.lng, 'MWL', 'Standard');
const futurePrayers = getPrayerTimes(thirtyDaysLater, city.lat, city.lng, 'MWL', 'Standard');
const nextPrayerCountdown = nextPrayer.time > today
  ? formatCountdown(nextPrayer.time.getTime() - today.getTime())
  : '';
const daylightVs30DaysAgo = -getDaylightChangeDays(today, -30, city.lat, city.lng);
const daylightIn30Days = getDaylightChangeDays(today, 30, city.lat, city.lng);
const fajrVs30DaysAgo = getClockTimeDelta(pastPrayers.fajr, prayers.fajr, city.timezone);
const maghribVs30DaysAgo = getClockTimeDelta(pastPrayers.maghrib, prayers.maghrib, city.timezone);
const fajrIn30Days = getClockTimeDelta(prayers.fajr, futurePrayers.fajr, city.timezone);
const maghribIn30Days = getClockTimeDelta(prayers.maghrib, futurePrayers.maghrib, city.timezone);
const localDateLabel = today.toLocaleDateString(chineseLocale, {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: city.timezone,
});
const currentYear = getLocalYear(today, city.timezone);
const prayerYearExtremes = getAnnualPrayerExtremes(currentYear, city.lat, city.lng, city.timezone, 'MWL', 'Standard');
const prayerSeasonalCheckpoints = getPrayerSeasonalCheckpoints(currentYear, city.lat, city.lng, 'MWL', 'Standard').map((checkpoint) => ({
  ...checkpoint,
  daylight: getSunTimes(checkpoint.date, city.lat, city.lng).daylightFormatted,
  label: ({
    'March Equinox': '春分',
    'June Solstice': '夏至',
    'September Equinox': '秋分',
    'December Solstice': '冬至',
  }[checkpoint.label] ?? checkpoint.label),
}));

const nearbyCities = getNearbyCities(city, 6);
const otherCities = getComparisonCities(city, 4);

const pagePath = `/prayer-times/${city.slug}/`;
const zhPath = localizePath('zh-cn', pagePath);
const sunrisePagePath = `/sunrise/${city.slug}/`;
const sunrisePath = localizePath('zh-cn', sunrisePagePath);
const pageUrl = `https://sunrisetime.co${zhPath}`;
const liveCityConfig = {
  kind: 'prayer',
  citySlug: city.slug,
  timezone: city.timezone,
  locale: chineseLocale,
  duration: {
    hourLabel: '小时',
    minuteLabel: '分钟',
    numberUnitSeparator: '',
    partSeparator: '',
  },
  leadTemplate: '当前本地时间为 {{localTime}}。下一次礼拜是 <strong>{{nextPrayerName}}</strong>，时间为 {{nextPrayerTime}}，还有 {{countdown}}。',
  countdownTemplate: '还有 {{countdown}}',
  prayerLabels: {
    fajr: getChinesePrayerName('Fajr'),
    sunrise: getChinesePrayerName('Sunrise'),
    dhuhr: getChinesePrayerName('Dhuhr'),
    asr: getChinesePrayerName('Asr'),
    maghrib: getChinesePrayerName('Maghrib'),
    isha: getChinesePrayerName('Isha'),
  },
};
const alternates = buildAlternateLinks([
  { hrefLang: 'en', path: pagePath },
  { hrefLang: 'es', path: localizePath('es', pagePath) },
  { hrefLang: 'zh-cn', path: zhPath },
  { hrefLang: 'x-default', path: pagePath },
]);
const languageLinks = buildLanguageSwitcherLinks(pagePath);

const prayerList = [
  { name: 'Fajr', time: prayers.fajr, desc: '黎明前的晨礼时间', icon: 'cloud-moon' },
  { name: 'Sunrise', time: prayers.sunrise, desc: '当天日出时间', icon: 'sunrise' },
  { name: 'Dhuhr', time: prayers.dhuhr, desc: '中午后的晌礼时间', icon: 'sun' },
  { name: 'Asr', time: prayers.asr, desc: '午后晡礼时间', icon: 'cloud-sun' },
  { name: 'Maghrib', time: prayers.maghrib, desc: '日落后的昏礼时间', icon: 'sunset' },
  { name: 'Isha', time: prayers.isha, desc: '夜间宵礼时间', icon: 'moon' },
];

const pageTitle = `${cityDisplayName}今日礼拜时间`;
const pageDesc = `${cityDisplayName}今天的礼拜时间：晨礼 ${formatTime(prayers.fajr, city.timezone, chineseLocale)}，晌礼 ${formatTime(prayers.dhuhr, city.timezone, chineseLocale)}，晡礼 ${formatTime(prayers.asr, city.timezone, chineseLocale)}，昏礼 ${formatTime(prayers.maghrib, city.timezone, chineseLocale)}，宵礼 ${formatTime(prayers.isha, city.timezone, chineseLocale)}。`;

const jsonLd = [
  {
    "@type": "WebPage",
    "@id": `${pageUrl}#webpage`,
    "name": pageTitle,
    "description": pageDesc,
    "url": pageUrl,
    "inLanguage": "zh-CN",
  },
  buildBreadcrumbJsonLd([
    { name: '首页', path: '/zh-cn/' },
    { name: '礼拜时间', path: zhPath },
    { name: cityName, path: zhPath },
  ]),
];
---

<Base
  title={`${pageTitle} - SunriseTime`}
  description={pageDesc}
  canonical={pageUrl}
  keywords={`${cityDisplayName} 礼拜时间, ${cityDisplayName} 晨礼时间, ${cityDisplayName} 昏礼时间`}
  jsonLd={jsonLd}
  lang="zh-CN"
  langPrefix="/zh-cn"
  alternates={alternates}
>
  <ChineseHeader languageLinks={languageLinks} currentLanguage="zh-cn" />

  <main class="city-page prayer-page" data-live-city-root data-live-config-id="cityLiveConfig">
    <div class="container">
      <nav class="breadcrumb" aria-label="面包屑导航">
        <a href="/zh-cn/">首页</a>
        <i data-lucide="chevron-right" class="icon-xs"></i>
        <a href={sunrisePath}>日出日落</a>
        <i data-lucide="chevron-right" class="icon-xs"></i>
        <span>{cityName}</span>
      </nav>

      <section class="prayer-hero glass-card-lg">
        <div class="prayer-hero-copy">
          <span class="city-kicker">本地礼拜时间</span>
          <h1><span class="gradient-text">{cityName}</span>礼拜时间</h1>
          <p class="city-lead" data-live-lead>
            下一次礼拜是 <strong>{getChinesePrayerName(nextPrayer.name)}</strong>，时间为 {formatTime(nextPrayer.time, city.timezone, chineseLocale)}{nextPrayerCountdown ? `，还有 ${nextPrayerCountdown}` : ''}。本页同时提供与礼拜相关的日出、日落和天光信息。
          </p>

          <div class="city-chip-row">
            <span class="city-chip city-country-badge">{locationLabel}</span>
            <span class="city-chip">{timezoneLabel}</span>
            <span class="city-chip">穆斯林世界联盟 · 标准影长</span>
          </div>

          <div class="city-action-row">
            <a href={sunrisePath} class="btn-secondary">
              <i data-lucide="sun" class="icon-xs"></i>
              查看日出日落
            </a>
            <a href="/zh-cn/cities/" class="btn-secondary">
              <i data-lucide="search" class="icon-xs"></i>
              换一座城市
            </a>
          </div>
        </div>

        <div class="prayer-hero-panel">
          <div class="prayer-next-hero glass-card">
            <span class="prayer-next-label">下一次礼拜</span>
            <strong class="prayer-next-name" data-live-next-prayer-name>{getChinesePrayerName(nextPrayer.name)}</strong>
            <span class="prayer-next-time" data-live-next-prayer-time>{formatTime(nextPrayer.time, city.timezone, chineseLocale)}</span>
            {nextPrayerCountdown && (
              <span class="prayer-next-countdown" data-live-next-prayer-countdown>{nextPrayerCountdown}</span>
            )}
          </div>
        </div>
      </section>

      <section class="detail-section" id="schedule" aria-label="礼拜时间表">
        <div class="detail-section-head">
          <h2><i data-lucide="clock" class="icon-md"></i> 礼拜时间表</h2>
          <p>以下时间适用于 {cityDisplayName} 的本地时区。</p>
        </div>

        <div class="prayer-grid">
          {prayerList.map((entry) => (
            <div
              class={`prayer-card glass-card ${nextPrayer.name === entry.name ? 'prayer-card-active' : ''}`}
              data-live-prayer-card={entry.name.toLowerCase()}
            >
              <i data-lucide={entry.icon} class="icon-md"></i>
              <span class="prayer-name">{getChinesePrayerName(entry.name)}</span>
              <span class="prayer-time" data-live-prayer-time={entry.name.toLowerCase()}>{formatTime(entry.time, city.timezone, chineseLocale)}</span>
              <span class="prayer-desc">{entry.desc}</span>
            </div>
          ))}
        </div>
      </section>

      <section class="detail-section" aria-label="太阳时间数据">
        <div class="detail-section-head">
          <h2><i data-lucide="sun" class="icon-md"></i> 与礼拜相关的太阳时间</h2>
        </div>
        <div class="detail-grid">
          <div class="detail-card glass-card">
            <h3>日出与日落</h3>
            <div class="detail-time">
              <div>
                <span class="data-label">日出</span>
                <span class="detail-time-value">{formatTime(sun.sunrise, city.timezone, chineseLocale)}</span>
              </div>
              <div>
                <span class="data-label">日落</span>
                <span class="detail-time-value">{formatTime(sun.sunset, city.timezone, chineseLocale)}</span>
              </div>
            </div>
            <span class="detail-duration">今天白昼时长约为 {formatChineseDuration(sun.daylightDuration)}</span>
          </div>
          <div class="detail-card glass-card">
            <h3>晨光与暮光</h3>
            <div class="detail-time">
              <div>
                <span class="data-label">晨光</span>
                <span class="detail-time-value">{formatTime(sun.dawn, city.timezone, chineseLocale)}</span>
              </div>
              <div>
                <span class="data-label">暮光</span>
                <span class="detail-time-value">{formatTime(sun.dusk, city.timezone, chineseLocale)}</span>
              </div>
            </div>
            <span class="detail-duration">太阳中天 {formatTime(sun.solarNoon, city.timezone, chineseLocale)}</span>
          </div>
        </div>
      </section>

      <section class="detail-section seo-content" aria-label="礼拜时间说明">
        <h2><i data-lucide="info" class="icon-md"></i> 如何看 {cityName} 的礼拜时间</h2>
        <div class="seo-text glass-card">
          <p>这页把今天的礼拜顺序、下一次礼拜时间，以及与礼拜相关的日出日落信息放在同一页里。当前默认按穆斯林世界联盟（MWL）标准计算，晡礼使用标准影长规则。</p>
        </div>
      </section>

      <section class="detail-section" aria-label="30天礼拜变化">
        <div class="detail-section-head">
          <h2><i data-lucide="calendar-range" class="icon-md"></i> 30 天礼拜变化</h2>
          <p>除了今天的整点时间，也可以直接看出晨礼和昏礼在一个月尺度上的移动速度。</p>
        </div>

        <div class="detail-grid">
          <div class="detail-card glass-card">
            <h3>相比 30 天前</h3>
            <div class="detail-time">
              <div>
                <span class="data-label">晨礼</span>
                <span class="detail-time-value">{formatRelativeClockShift(fajrVs30DaysAgo, '30 天前')}</span>
              </div>
              <div>
                <span class="data-label">昏礼</span>
                <span class="detail-time-value">{formatRelativeClockShift(maghribVs30DaysAgo, '30 天前')}</span>
              </div>
            </div>
            <span class="detail-duration">{formatRelativeDaylight(daylightVs30DaysAgo, '30 天前')}</span>
          </div>

          <div class="detail-card glass-card">
            <h3>未来 30 天预估</h3>
            <div class="detail-time">
              <div>
                <span class="data-label">晨礼</span>
                <span class="detail-time-value">{formatRelativeClockShift(fajrIn30Days, '今天')}</span>
              </div>
              <div>
                <span class="data-label">昏礼</span>
                <span class="detail-time-value">{formatRelativeClockShift(maghribIn30Days, '今天')}</span>
              </div>
            </div>
            <span class="detail-duration">{formatRelativeDaylight(daylightIn30Days, '今天')}</span>
          </div>
        </div>
      </section>

      <section class="detail-section" aria-label="年度礼拜极值">
        <div class="detail-section-head">
          <h2><i data-lucide="trophy" class="icon-md"></i> {currentYear} 年度礼拜极值</h2>
          <p>这组年尺度数据会告诉你本地全年最早和最晚的晨礼与昏礼，大幅减少来回切日期的成本。</p>
        </div>

        <div class="detail-grid">
          <div class="detail-card glass-card">
            <h3>晨礼极值</h3>
            <div class="detail-time">
              <div>
                <span class="data-label">全年最早晨礼</span>
                <span class="detail-time-value">{formatTime(prayerYearExtremes.earliestFajr.time, city.timezone, chineseLocale)}</span>
              </div>
              <div>
                <span class="data-label">全年最晚晨礼</span>
                <span class="detail-time-value">{formatTime(prayerYearExtremes.latestFajr.time, city.timezone, chineseLocale)}</span>
              </div>
            </div>
            <span class="detail-duration">{formatCalendarDate(prayerYearExtremes.earliestFajr.date)} · {formatCalendarDate(prayerYearExtremes.latestFajr.date)}</span>
          </div>

          <div class="detail-card glass-card">
            <h3>昏礼极值</h3>
            <div class="detail-time">
              <div>
                <span class="data-label">全年最早昏礼</span>
                <span class="detail-time-value">{formatTime(prayerYearExtremes.earliestMaghrib.time, city.timezone, chineseLocale)}</span>
              </div>
              <div>
                <span class="data-label">全年最晚昏礼</span>
                <span class="detail-time-value">{formatTime(prayerYearExtremes.latestMaghrib.time, city.timezone, chineseLocale)}</span>
              </div>
            </div>
            <span class="detail-duration">{formatCalendarDate(prayerYearExtremes.earliestMaghrib.date)} · {formatCalendarDate(prayerYearExtremes.latestMaghrib.date)}</span>
          </div>
        </div>
      </section>

      <section class="detail-section" aria-label="季节性礼拜节点">
        <div class="detail-section-head">
          <h2><i data-lucide="trees" class="icon-md"></i> 季节性礼拜节点</h2>
          <p>以四个季节节点查看礼拜时间，比逐天翻历更快判断全年节奏。</p>
        </div>

        <div class="glass-card">
          <table>
            <thead>
              <tr>
                <th>节点</th>
                <th>日期</th>
                <th>晨礼</th>
                <th>日出</th>
                <th>昏礼</th>
                <th>宵礼</th>
                <th>日照时长</th>
              </tr>
            </thead>
            <tbody>
              {prayerSeasonalCheckpoints.map((checkpoint) => (
                <tr>
                  <td>{checkpoint.label}</td>
                  <td>{formatCalendarDate(checkpoint.date)}</td>
                  <td>{formatTime(checkpoint.fajr, city.timezone, chineseLocale)}</td>
                  <td>{formatTime(checkpoint.sunrise, city.timezone, chineseLocale)}</td>
                  <td>{formatTime(checkpoint.maghrib, city.timezone, chineseLocale)}</td>
                  <td>{formatTime(checkpoint.isha, city.timezone, chineseLocale)}</td>
                  <td>{checkpoint.daylight}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="detail-section" id="nearby" aria-label="相近城市">
        <div class="detail-section-head">
          <h2><i data-lucide="map-pin" class="icon-md"></i> 同区域其他城市</h2>
        </div>
        <div class="nearby-grid">
          {nearbyCities.map((entry) => (
            <a href={`/zh-cn/prayer-times/${entry.slug}/`} class="nearby-card glass-card">
              <span class="nearby-name">{getChineseCityName(entry)}</span>
              <span class="nearby-country">{getChineseCityLocationLabel(entry)}</span>
            </a>
          ))}
        </div>

        {otherCities.length > 0 && (
          <>
            <h3 class="other-cities-title">更多可对比城市</h3>
            <div class="nearby-grid">
              {otherCities.map((entry) => (
                <a href={`/zh-cn/prayer-times/${entry.slug}/`} class="nearby-card glass-card">
                  <span class="nearby-name">{getChineseCityName(entry)}</span>
                  <span class="nearby-country">{getChineseCityLocationLabel(entry)}</span>
                </a>
              ))}
            </div>
          </>
        )}
      </section>
    </div>
  </main>

  <ChineseFooter />
  <script type="application/json" id="cityLiveConfig" set:html={JSON.stringify(liveCityConfig)} />
</Base>

