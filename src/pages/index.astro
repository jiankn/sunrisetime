---
/**
 * SunriseTime.co — 首页
 * 关键词: sunrise sunset times city search
 */
import Base from '@layouts/Base.astro';
import Header from '@components/Header.astro';
import Hero from '@components/Hero.astro';
import TrustBadges from '@components/TrustBadges.astro';
import Features from '@components/Features.astro';
import Dashboard from '@components/Dashboard.astro';
import AdUnit from '@components/AdUnit.astro';
import TopCities from '@components/TopCities.astro';
import FAQ from '@components/FAQ.astro';
import CTA from '@components/CTA.astro';
import Footer from '@components/Footer.astro';
import { totalCities } from '@data/site';

const jsonLd = [
  {
    "@type": "WebSite",
    "@id": "https://sunrisetime.co/#website",
    "name": "SunriseTime",
    "url": "https://sunrisetime.co/",
    "description": `Search today's sunrise, sunset, golden hour, and moon phase times for ${totalCities} indexed cities worldwide.`,
    "inLanguage": "en",
    "publisher": {
      "@id": "https://sunrisetime.co/#organization"
    }
  },
  {
    "@type": "Organization",
    "@id": "https://sunrisetime.co/#organization",
    "name": "SunriseTime",
    "url": "https://sunrisetime.co/"
  },
  {
    "@type": "FAQPage",
    "@id": "https://sunrisetime.co/#faq",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How accurate is SunriseTime data?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "SunriseTime uses the NOAA Solar Calculator algorithm, providing sunrise and sunset times accurate to within 1 minute for any location worldwide."
        }
      },
      {
        "@type": "Question",
        "name": "How many cities does SunriseTime cover?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `SunriseTime currently publishes timing pages for ${totalCities} indexed cities in the public directory.`
        }
      },
      {
        "@type": "Question",
        "name": "Does SunriseTime provide golden hour times?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, SunriseTime calculates precise golden hour windows for both morning and evening, perfect for photographers and filmmakers."
        }
      }
    ]
  }
];
---

<Base
  title="SunriseTime — Search Today's Sunrise & Sunset Times by City"
  description={`Search today's sunrise, sunset, golden hour, moon phase, and prayer times for ${totalCities} indexed cities worldwide. Find your city fast and plan the light in seconds.`}
  keywords="sunrise time, sunset time, city search, golden hour, moon phase, prayer times, daylight"
  jsonLd={jsonLd}
>
  <Header />
  <Hero />
  <TrustBadges />
  <Features />
  <Dashboard />
  <AdUnit id="ad-mid" />
  <TopCities />
  <FAQ />
  <AdUnit id="ad-bottom" />
  <CTA />
  <Footer />
</Base>
