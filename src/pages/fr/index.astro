---
import Base from '@layouts/Base.astro';
import FrenchHeader from '@components/FrenchHeader.astro';
import FrenchFooter from '@components/FrenchFooter.astro';
import { allCities, regionHubs, totalCities } from '@data/site';
import { buildLanguageSwitcherLinks, localizePath } from '@i18n/config';
import {
  getFrenchCityAliases,
  getFrenchCityDisplayName,
  getFrenchCityName,
  getFrenchCityLocationLabel,
  getFrenchCountryName,
  getFrenchMoonPhase,
  getFrenchPrayerName,
  getFrenchRegionName,
  frenchHomeFaqs,
  frenchLocale,
} from '@i18n/french';
import { getGoldenHour, getSunTimes, formatTime } from '@utils/sun';
import { getMoonData } from '@utils/moon';
import { getNextPrayer } from '@utils/prayer-times';
import { buildAlternateLinks } from '@utils/seo';

const pagePath = '/';
const alternates = buildAlternateLinks([
  { hrefLang: 'en', path: pagePath },
  { hrefLang: 'fr', path: localizePath('fr', pagePath) },
  { hrefLang: 'x-default', path: pagePath },
]);
const languageLinks = buildLanguageSwitcherLinks(pagePath);

const previewSlugs = ['new-york', 'madrid', 'dubai', 'mexico-city', 'bogota', 'buenos-aires'];
const now = new Date();

function buildPreviewEntry(slug: string) {
  const city = allCities.find((entry) => entry.slug === slug);
  if (!city) return null;

  const sun = getSunTimes(now, city.lat, city.lng);
  const golden = getGoldenHour(now, city.lat, city.lng);
  const moon = getMoonData(now, city.lat, city.lng);
  const nextPrayer = getNextPrayer(now, city.lat, city.lng, 'MWL', 'Standard');

  let nextEventLabel = 'Prochain lever du soleil';
  let nextEventTime = formatTime(sun.sunrise, city.timezone, frenchLocale);
  let nextEventSupport = `L heure doree du matin se termine a ${formatTime(golden.morning.end, city.timezone, frenchLocale)}.`;

  if (now >= sun.sunrise && now < sun.sunset) {
    nextEventLabel = 'Prochain coucher du soleil';
    nextEventTime = formatTime(sun.sunset, city.timezone, frenchLocale);
    nextEventSupport = `L heure doree du soir commence a ${formatTime(golden.evening.start, city.timezone, frenchLocale)}.`;
  } else if (now >= sun.sunset) {
    const tomorrow = new Date(now);
    tomorrow.setDate(tomorrow.getDate() + 1);
    const tomorrowSun = getSunTimes(tomorrow, city.lat, city.lng);
    nextEventLabel = 'Lever du soleil de demain';
    nextEventTime = formatTime(tomorrowSun.sunrise, city.timezone, frenchLocale);
    nextEventSupport = `Demain offre ${tomorrowSun.daylightFormatted} de lumiere du jour.`;
  }

  return {
    slug: city.slug,
    name: city.name,
    displayName: getFrenchCityDisplayName(city, { includeAdmin1: Boolean(city.admin1) }),
    country: city.country,
    countryLabel: getFrenchCityLocationLabel(city, { includeAdmin1: Boolean(city.admin1) }),
    timezone: city.timezone,
    aliases: getFrenchCityAliases(city),
    admin1: city.admin1 ?? '',
    caption: `${getFrenchCityLocationLabel(city, { includeAdmin1: Boolean(city.admin1) })} · ${now.toLocaleDateString(frenchLocale, {
      weekday: 'short',
      month: 'short',
      day: 'numeric',
      timeZone: city.timezone,
    })}`,
    sunrise: formatTime(sun.sunrise, city.timezone, frenchLocale),
    sunset: formatTime(sun.sunset, city.timezone, frenchLocale),
    daylight: sun.daylightFormatted,
    golden: `${formatTime(golden.evening.start, city.timezone, frenchLocale)} - ${formatTime(golden.evening.end, city.timezone, frenchLocale)}`,
    moon: `${getFrenchMoonPhase(moon.phaseName)} · ${moon.illumination}%`,
    prayer: `${getFrenchPrayerName(nextPrayer.name)} ${formatTime(nextPrayer.time, city.timezone, frenchLocale)}`,
    nextEventLabel,
    nextEventTime,
    nextEventSupport,
  };
}

const previewCities = previewSlugs
  .map((slug) => buildPreviewEntry(slug))
  .filter((entry): entry is NonNullable<ReturnType<typeof buildPreviewEntry>> => Boolean(entry));

const heroCity = previewCities[0];

const searchCities = allCities.map((city) => ({
  name: city.name,
  displayName: getFrenchCityDisplayName(city, { includeAdmin1: Boolean(city.admin1) }),
  slug: city.slug,
  country: city.country,
  countryLabel: getFrenchCityLocationLabel(city, { includeAdmin1: Boolean(city.admin1) }),
  admin1: city.admin1 ?? '',
  aliases: getFrenchCityAliases(city),
  lat: city.lat,
  lng: city.lng,
  population: city.population,
}));

const regionGroups = regionHubs.map((region) => ({
  id: region.slug,
  name: getFrenchRegionName(region.slug, region.name),
  cities: region.cities.slice(0, 6).map((city) => ({
    slug: city.slug,
    name: getFrenchCityName(city),
    country: getFrenchCityLocationLabel(city, { includeAdmin1: Boolean(city.admin1) }),
  })),
}));

const jsonLd = [
  {
    "@type": "WebSite",
    "@id": "https://sunrisetime.co/fr/#website",
    "name": "SunriseTime en francais",
    "url": "https://sunrisetime.co/fr/",
    "description": `Consultez le lever du soleil, le coucher du soleil, l heure doree et les horaires de priere de ${totalCities} villes indexees.`,
    "inLanguage": "fr",
    "publisher": {
      "@id": "https://sunrisetime.co/#organization"
    }
  },
  {
    "@type": "Organization",
    "@id": "https://sunrisetime.co/#organization",
    "name": "SunriseTime",
    "url": "https://sunrisetime.co/"
  },
  {
    "@type": "FAQPage",
    "@id": "https://sunrisetime.co/fr/#faq",
    "mainEntity": frenchHomeFaqs.map((item) => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer,
      },
    })),
  },
];
---

<Base
  title={`Lever du soleil et coucher du soleil aujourd hui dans ${totalCities} villes - SunriseTime`}
  description={`Recherchez le lever du soleil, le coucher du soleil, l heure doree, la phase lunaire et les horaires de priere de ${totalCities} villes. Version SEO en francais avec URLs indexables et contenu principal localise.`}
  canonical="https://sunrisetime.co/fr/"
  keywords="lever du soleil aujourd hui, coucher du soleil aujourd hui, heure doree, horaires de priere, villes"
  jsonLd={jsonLd}
  lang="fr"
  alternates={alternates}
>
  <FrenchHeader languageLinks={languageLinks} currentLanguage="fr" />

  <main class="resource-page">
    <section class="snapshot-hero" id="search">
      <div class="container snapshot-hero-shell">
        <div class="snapshot-hero-copy">
          <div class="hero-badge">
            <i data-lucide="languages" class="icon-xs"></i>
            <span>Pilote SEO en francais</span>
          </div>

          <div class="hero-search-panel glass-card-lg" data-hero-search>
            <div class="hero-search-head">
              <div>
                <span class="hero-search-label">Trouvez la reponse du jour</span>
                <strong class="hero-search-title">Recherchez une ville et ouvrez sa page locale en quelques secondes</strong>
              </div>
            </div>
            <div class="hero-search-shell hero-search-shell-lg">
              <i data-lucide="search" class="icon-sm"></i>
              <input
                id="heroCitySearch"
                type="text"
                data-city-search-input
                placeholder="Exemple : Paris, New York, Montreal"
                autocomplete="off"
                aria-autocomplete="list"
                aria-controls="heroSearchResults"
                aria-expanded="false"
                aria-label="Rechercher une ville"
                role="combobox"
              >
              <button type="button" class="hero-location-btn hero-location-btn-inline" data-use-location>
                <i data-lucide="locate-fixed" class="icon-sm"></i>
                <span class="hero-location-text" data-location-label aria-live="polite" aria-atomic="true">Utiliser ma position</span>
              </button>
            </div>
            <p class="hero-search-helper">Commencez par une ville, un pays ou un alias courant.</p>
            <div class="hero-search-results" id="heroSearchResults" data-search-results role="listbox"></div>

            <div class="hero-quick-row">
              <span class="hero-quick-label">Apercus rapides</span>
              <div class="hero-preview-switches">
                {previewCities.map((city, index) => (
                  <button
                    type="button"
                    class={`hero-city-pill ${index === 0 ? 'active' : ''}`}
                    data-hero-city={city.slug}
                  >
                    {city.displayName}
                  </button>
                ))}
              </div>
            </div>
          </div>

          <header class="resource-header" style="padding-top:0;margin-top:2rem;">
            <span class="section-badge">
              <i data-lucide="sun-medium" class="icon-xs"></i>
              Lever du soleil, coucher du soleil et priere
            </span>
            <h1>Consultez le lever et le coucher du soleil d aujourd hui par ville.</h1>
            <p class="resource-subtitle">SunriseTime en francais repond d abord a l intention principale: heure du lever du soleil, heure du coucher du soleil, duree du jour, heure doree, phase lunaire et acces rapide aux horaires de priere.</p>
            <div class="resource-meta">
              <span class="resource-meta-chip">{totalCities} villes indexees</span>
              <span class="resource-meta-chip">Canonical dedie</span>
              <span class="resource-meta-chip">hreflang reel</span>
            </div>
          </header>
        </div>

        <div class="hero-snapshot-panel glass-card-lg">
          <div class="hero-panel-top">
            <div class="hero-panel-copy">
              <span class="hero-panel-label">Apercu instantane</span>
              <h2>
                <span data-hero-city-name>{heroCity.displayName}</span>
                <span class="hero-panel-country" data-hero-country>{heroCity.countryLabel}</span>
              </h2>
              <p data-hero-caption>{heroCity.caption}</p>
            </div>
            <a class="btn-secondary-sm hero-open-link" data-hero-open href={`/fr/sunrise/${heroCity.slug}/`}>
              <span>Ouvrir la page</span>
              <i data-lucide="arrow-up-right" class="icon-sm"></i>
            </a>
          </div>

          <div class="hero-next-card">
            <span class="hero-next-label" data-hero-next-label>{heroCity.nextEventLabel}</span>
            <strong class="hero-next-time" data-hero-next-time>{heroCity.nextEventTime}</strong>
            <span class="hero-next-sub" data-hero-next-support>{heroCity.nextEventSupport}</span>
          </div>

          <div class="hero-mini-grid">
            <div class="hero-mini-card glass-card">
              <span class="hero-mini-label">Lever du soleil</span>
              <strong data-hero-sunrise>{heroCity.sunrise}</strong>
            </div>
            <div class="hero-mini-card glass-card">
              <span class="hero-mini-label">Coucher du soleil</span>
              <strong data-hero-sunset>{heroCity.sunset}</strong>
            </div>
            <div class="hero-mini-card glass-card">
              <span class="hero-mini-label">Lumiere du jour</span>
              <strong data-hero-daylight>{heroCity.daylight}</strong>
            </div>
            <div class="hero-mini-card glass-card">
              <span class="hero-mini-label">Heure doree</span>
              <strong data-hero-golden>{heroCity.golden}</strong>
            </div>
            <div class="hero-mini-card glass-card">
              <span class="hero-mini-label">Luna</span>
              <strong data-hero-moon>{heroCity.moon}</strong>
            </div>
            <div class="hero-mini-card glass-card">
              <span class="hero-mini-label">Prochaine priere</span>
              <strong data-hero-prayer>{heroCity.prayer}</strong>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="container">
      <section class="resource-grid">
        <article class="resource-card glass-card">
          <h2>Ce que couvre cette version</h2>
          <ul class="resource-list">
            <li>Une page d accueil en francais avec recherche par ville et routes indexables sous `/fr/`.</li>
            <li>Des pages de lever du soleil, coucher du soleil et priere par ville avec metadonnees localisees.</li>
            <li>Des pages de confiance: a propos, confidentialite, conditions, contact et sitemap HTML.</li>
          </ul>
        </article>

        <article class="resource-card glass-card">
          <h2>Ce que Google voit d abord</h2>
          <ul class="resource-list">
            <li>Title, description, H1 et corps principal en francais.</li>
            <li>Un canonical dedie pour chaque URL francaise.</li>
            <li>Un cluster hreflang coherent entre anglais et francais.</li>
          </ul>
        </article>
      </section>

      <section class="resource-section" id="top-cities">
        <div class="detail-section-head">
          <h2>Villes mises en avant</h2>
          <p>Ouvrez une ville populaire et allez directement a la reponse du jour.</p>
        </div>

        <div class="cities-grid">
          {regionGroups.map((group) => (
            <div class="city-group glass-card" id={`fr-${group.id}`}>
              <h3>
                <i data-lucide="globe" class="icon-sm"></i>
                {group.name}
              </h3>
              <ul class="city-list">
                {group.cities.map((city) => (
                  <li>
                    <a href={`/fr/sunrise/${city.slug}/`} class="city-link">
                      <span class="city-name">{city.name}</span>
                      <span class="city-country">{city.country}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>

        <div class="cities-cta">
          <a href="/fr/cities/" class="btn-secondary">
            <i data-lucide="globe" class="icon-xs"></i>
            Voir l index complet des villes
          </a>
        </div>
      </section>

      <section class="faq" id="faq">
        <div class="section-header">
          <span class="section-badge">
            <i data-lucide="help-circle" class="icon-xs"></i>
            FAQ
          </span>
          <h2>Questions frequentes sur la version francaise</h2>
          <p class="section-subtitle">Cette couche multilingue sert a ajouter des URLs utiles et explorables, pas a dupliquer l anglais avec une traduction superficielle.</p>
        </div>

        <div class="faq-list">
          {frenchHomeFaqs.map((item, index) => (
            <details class="faq-item glass-card" id={`fr-faq-${index + 1}`}>
              <summary>
                <span>{item.question}</span>
                <i data-lucide="chevron-down" class="icon-sm faq-icon"></i>
              </summary>
              <div class="faq-answer">
                <p>{item.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </section>

      <section class="resource-callout glass-card-lg" style="margin-top:2rem;">
        <div>
          <span class="resource-callout-label">Etape suivante</span>
          <h2>Commencez par une ville et ouvrez la bonne URL des la premiere recherche.</h2>
          <p>Si vous connaissez deja la ville, ouvrez sa page de lever du soleil ou de priere. Si vous comparez encore des destinations, passez par l index des villes.</p>
        </div>
        <div class="resource-link-row">
          <a href="/fr/cities/" class="btn-primary-sm">Index des villes</a>
          <a href="/fr/guides/" class="btn-secondary-sm">Guides</a>
          <a href="/fr/methodology/" class="btn-secondary-sm">Methodologie</a>
          <a href="/fr/about/" class="btn-secondary-sm">A propos de SunriseTime</a>
        </div>
      </section>
    </div>
  </main>

  <FrenchFooter />

  <script type="application/json" id="heroPreviewData" set:html={JSON.stringify(previewCities)} />
  <script type="application/json" id="heroSearchData" set:html={JSON.stringify(searchCities)} />
  <script
    type="application/json"
    id="heroSearchConfig"
    set:html={JSON.stringify({
      noMatchTitle: 'Nous n avons pas trouve cette ville',
      noMatchSubtitle: 'Essayez une autre orthographe ou une ville voisine',
      openCityPage: 'Ouvrir la page',
      useMyLocation: 'Utiliser ma position',
      locationUnavailable: 'Localisation indisponible',
      locating: 'Localisation...',
      nearestUnavailable: 'Aucune ville proche trouvee',
      locationBlocked: 'Permission bloquee',
    })}
  />
</Base>


