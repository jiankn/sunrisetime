---
import FrenchFooter from '@components/FrenchFooter.astro';
import FrenchHeader from '@components/FrenchHeader.astro';
import GoldenHourCityContent from '@components/GoldenHourCityContent.astro';
import { getCityBySlug } from '@data/site';
import Base from '@layouts/Base.astro';
import { buildLanguageSwitcherLinks, localizePath } from '@i18n/config';
import { frenchGoldenHourCopy } from '@i18n/golden-hour-page';
import {
  getFrenchCityDisplayName,
  getFrenchCityLocationLabel,
  getFrenchCityName,
} from '@i18n/french';
import { buildAlternateLinks, buildBreadcrumbJsonLd } from '@utils/seo';
import { formatTime, getGoldenHour } from '@utils/sun';

export const prerender = false;
Astro.response.headers.set('Cache-Control', 'public, max-age=300, s-maxage=3600');

const city = getCityBySlug(Astro.params.city ?? '');

if (!city) {
  return new Response(null, { status: 404, statusText: 'Not found' });
}

const today = new Date();
const golden = getGoldenHour(today, city.lat, city.lng);
const cityName = getFrenchCityName(city);
const cityDisplayName = getFrenchCityDisplayName(city, { includeAdmin1: Boolean(city.admin1) });
const cityLocationLabel = getFrenchCityLocationLabel(city, { includeAdmin1: Boolean(city.admin1) });
const pagePath = `/golden-hour/${city.slug}/`;
const localizedPath = localizePath('fr', pagePath);
const pageUrl = `https://sunrisetime.co${localizedPath}`;
const alternates = buildAlternateLinks([
  { hrefLang: 'en', path: pagePath },
  { hrefLang: 'fr', path: localizedPath },
  { hrefLang: 'x-default', path: pagePath },
]);
const languageLinks = buildLanguageSwitcherLinks(pagePath);
const pageTitle = frenchGoldenHourCopy.pageTitle(cityDisplayName);
const pageDesc = frenchGoldenHourCopy.pageDescription(
  cityDisplayName,
  formatTime(golden.morning.start, city.timezone, frenchGoldenHourCopy.locale),
  formatTime(golden.morning.end, city.timezone, frenchGoldenHourCopy.locale),
  formatTime(golden.evening.start, city.timezone, frenchGoldenHourCopy.locale),
);

const jsonLd = [
  {
    "@type": "WebPage",
    "@id": `${pageUrl}#webpage`,
    "name": pageTitle,
    "description": pageDesc,
    "url": pageUrl,
    "inLanguage": "fr",
  },
  buildBreadcrumbJsonLd([
    { name: 'Accueil', path: '/fr/' },
    { name: 'Villes', path: '/fr/cities/' },
    { name: cityName, path: localizedPath },
  ]),
  {
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    "mainEntity": [
      {
        "@type": "Question",
        "name": frenchGoldenHourCopy.faqMorningQuestion(cityName),
        "acceptedAnswer": {
          "@type": "Answer",
          "text": frenchGoldenHourCopy.faqMorningAnswer(
            cityName,
            formatTime(golden.morning.start, city.timezone, frenchGoldenHourCopy.locale),
            formatTime(golden.morning.end, city.timezone, frenchGoldenHourCopy.locale),
          ),
        },
      },
      {
        "@type": "Question",
        "name": frenchGoldenHourCopy.faqEveningQuestion(cityName),
        "acceptedAnswer": {
          "@type": "Answer",
          "text": frenchGoldenHourCopy.faqEveningAnswer(
            cityName,
            formatTime(golden.evening.start, city.timezone, frenchGoldenHourCopy.locale),
            formatTime(golden.evening.end, city.timezone, frenchGoldenHourCopy.locale),
          ),
        },
      },
    ],
  },
];
---

<Base
  title={`${pageTitle} - SunriseTime Francais`}
  description={pageDesc}
  canonical={pageUrl}
  keywords={frenchGoldenHourCopy.keywords(cityDisplayName)}
  jsonLd={jsonLd}
  lang="fr"
  alternates={alternates}
>
  <FrenchHeader languageLinks={languageLinks} currentLanguage="fr" />
  <GoldenHourCityContent
    city={city}
    cityName={cityName}
    cityDisplayName={cityDisplayName}
    cityLocationLabel={cityLocationLabel}
    languageCode="fr"
    locale={frenchGoldenHourCopy.locale}
    copy={frenchGoldenHourCopy}
    formatCityName={getFrenchCityName}
    formatCityLocationLabel={(entry) => getFrenchCityLocationLabel(entry, { includeAdmin1: Boolean(entry.admin1) })}
  />
  <FrenchFooter />
</Base>
