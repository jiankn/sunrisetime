---
/**
 * CTA Section — 底部转化区
 */
---

<section class="cta-section">
  <div class="container">
    <div class="cta-card glass-card-lg">
      <h2>Search today&apos;s light in your city</h2>
      <p>Start with a city search, jump into the local page, and get the timing that matters without extra steps or account friction.</p>
      <div class="cta-buttons">
        <a href="#search" class="btn-primary" id="ctaMainBtn">
          <i data-lucide="search" class="icon-xs"></i>
          Start with Search
        </a>
        <a href="/cities/" class="btn-secondary" id="ctaSecBtn">
          <i data-lucide="globe" class="icon-xs"></i>
          Browse All Cities
        </a>
      </div>
    </div>
  </div>
</section>
