---
/**
 * CTA Section — 底部转化区
 */
---

<section class="cta-section">
  <div class="container">
    <div class="cta-card glass-card-lg">
      <h2>Start Tracking Sunrise & Sunset Times Today</h2>
      <p>Join thousands of photographers, travelers, and developers who rely on SunriseTime for precise sun and moon data. 100% free, forever — no signup required.</p>
      <div class="cta-buttons">
        <a href="#dashboard" class="btn-primary" id="ctaMainBtn">
          <i data-lucide="search" class="icon-xs"></i>
          Search Your City
        </a>
        <a href="#cities" class="btn-secondary" id="ctaSecBtn">
          <i data-lucide="globe" class="icon-xs"></i>
          Browse Top Cities
        </a>
      </div>
    </div>
  </div>
</section>
