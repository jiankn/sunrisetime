---
/**
 * Planner Section — 按使用场景组织内容
 * 左栏: 3 张场景卡片 (Photography / Travel / Prayer)
 * 右栏: Example Rhythm + Popular Right Now + Quick Prayer Check
 */
import cities from '@data/cities.json';
import { getSunTimes, getGoldenHour, getDaylightSeries, formatTime } from '@utils/sun';
import { getNextPrayer, getPrayerTimes } from '@utils/prayer-times';

const plannerNow = new Date();

// --- Example Rhythm (New York) ---
const plannerCity = cities.cities.find(city => city.slug === 'new-york') ?? cities.cities[0];
const plannerSun = getSunTimes(plannerNow, plannerCity.lat, plannerCity.lng);
const plannerGolden = getGoldenHour(plannerNow, plannerCity.lat, plannerCity.lng);
const plannerPrayer = getNextPrayer(plannerNow, plannerCity.lat, plannerCity.lng, 'MWL', 'Standard');
const plannerTrend = getDaylightSeries(plannerNow, 5, plannerCity.lat, plannerCity.lng);
const plannerTrendDelta = Math.round((plannerTrend[plannerTrend.length - 1].hours - plannerTrend[0].hours) * 60);
const plannerMoments = [
  {
    label: 'Before sunrise',
    value: formatTime(plannerSun.dawn, plannerCity.timezone),
    detail: 'Civil dawn begins',
  },
  {
    label: 'Morning golden hour',
    value: `${formatTime(plannerGolden.morning.start, plannerCity.timezone)} to ${formatTime(plannerGolden.morning.end, plannerCity.timezone)}`,
    detail: 'Soft light, low sun angle',
  },
  {
    label: 'Sunset window',
    value: formatTime(plannerSun.sunset, plannerCity.timezone),
    detail: `Next prayer ${plannerPrayer.name} at ${formatTime(plannerPrayer.time, plannerCity.timezone)}`,
  },
];

// --- Popular Right Now (4 diverse cities) ---
const popularSlugs = ['london', 'dubai', 'tokyo', 'sydney'];
const popularCities = popularSlugs
  .map(slug => cities.cities.find(c => c.slug === slug))
  .filter(Boolean)
  .map(city => {
    const sun = getSunTimes(plannerNow, city!.lat, city!.lng);
    return {
      name: city!.name,
      slug: city!.slug,
      country: city!.country,
      sunrise: formatTime(sun.sunrise, city!.timezone),
      sunset: formatTime(sun.sunset, city!.timezone),
    };
  });

// --- Quick Prayer Check (Dubai) ---
const prayerCity = cities.cities.find(c => c.slug === 'dubai') ?? cities.cities[0];
const prayerCityTimes = getPrayerTimes(plannerNow, prayerCity.lat, prayerCity.lng, 'MWL', 'Standard');
const prayerCityNext = getNextPrayer(plannerNow, prayerCity.lat, prayerCity.lng, 'MWL', 'Standard');
const prayerSchedule = [
  { name: 'Fajr',    time: prayerCityTimes.fajr },
  { name: 'Dhuhr',   time: prayerCityTimes.dhuhr },
  { name: 'Asr',     time: prayerCityTimes.asr },
  { name: 'Maghrib', time: prayerCityTimes.maghrib },
  { name: 'Isha',    time: prayerCityTimes.isha },
];
---

<section class="planner-section" id="planner">
  <div class="container">
    <div class="section-header">
      <span class="section-badge">
        <i data-lucide="compass" class="icon-xs"></i>
        Daily Planner
      </span>
      <h2>Choose the moment that matters, then go straight to the answer.</h2>
      <p class="section-subtitle">A better tool follows the way people plan a day: first light, best light, prayer windows, then nearby alternatives.</p>
    </div>

    <div class="planner-layout">
      <div class="planner-card-grid">
        <article class="planner-card glass-card">
          <div class="planner-card-icon icon-golden">
            <i data-lucide="camera" class="icon-lg"></i>
          </div>
          <h3>Photography first</h3>
          <p>Lead with golden hour, twilight, and moon illumination so the best shooting window is visible before anything else.</p>
          <a href="#search" class="feature-link">Search a city <i data-lucide="arrow-right" class="icon-xs"></i></a>
        </article>

        <article class="planner-card glass-card">
          <div class="planner-card-icon icon-daylight">
            <i data-lucide="backpack" class="icon-lg"></i>
          </div>
          <h3>Travel and routine</h3>
          <p>See sunrise, sunset, daylight length, and the next change in light at a glance so you can plan the day without reading a wall of content.</p>
          <a href="#cities" class="feature-link">Browse popular cities <i data-lucide="arrow-right" class="icon-xs"></i></a>
        </article>

        <article class="planner-card glass-card">
          <div class="planner-card-icon icon-prayer">
            <i data-lucide="clock-3" class="icon-lg"></i>
          </div>
          <h3>Prayer support</h3>
          <p>Keep prayer times present but secondary, so they are easy to reach when relevant without crowding the main sunrise and sunset answer.</p>
          <a href="/guides/prayer-times/" class="feature-link">See how it works <i data-lucide="arrow-right" class="icon-xs"></i></a>
        </article>
      </div>

      <div class="planner-right-stack">
        <!-- Panel 1: Example Rhythm -->
        <div class="planner-rhythm glass-card-lg">
          <div class="planner-rhythm-head">
            <div>
              <span class="planner-rhythm-kicker">Example rhythm</span>
              <h3>{plannerCity.name} today</h3>
            </div>
            <span class="planner-rhythm-trend">
              {plannerTrendDelta >= 0 ? '+' : ''}{plannerTrendDelta}m daylight this week
            </span>
          </div>

          <div class="planner-rhythm-list">
            {plannerMoments.map(moment => (
              <div class="planner-rhythm-row">
                <div>
                  <span class="planner-rhythm-label">{moment.label}</span>
                  <strong>{moment.value}</strong>
                </div>
                <span class="planner-rhythm-detail">{moment.detail}</span>
              </div>
            ))}
          </div>

          <div class="planner-bar-group">
            {plannerTrend.map(point => (
              <div class="planner-bar-col">
                <span>{point.hours.toFixed(1)}h</span>
                <div class="planner-bar" style={`height:${Math.round((point.hours / 16) * 100)}%`}></div>
                <small>{point.date.toLocaleDateString('en-US', { weekday: 'short', timeZone: plannerCity.timezone })}</small>
              </div>
            ))}
          </div>
        </div>

        <!-- Panel 2: Popular Right Now -->
        <div class="planner-popular glass-card-lg">
          <div class="planner-popular-head">
            <i data-lucide="trending-up" class="icon-sm"></i>
            <span>Popular right now</span>
          </div>
          <div class="planner-popular-list">
            {popularCities.map(city => (
              <a href={`/sunrise/${city.slug}/`} class="planner-popular-row">
                <span class="planner-popular-name">{city.name}</span>
                <span class="planner-popular-times">
                  <span class="planner-pop-rise">↑ {city.sunrise}</span>
                  <span class="planner-pop-set">↓ {city.sunset}</span>
                </span>
              </a>
            ))}
          </div>
        </div>

        <!-- Panel 3: Quick Prayer Check -->
        <div class="planner-prayer-check glass-card-lg">
          <div class="planner-prayer-head">
            <div>
              <span class="planner-rhythm-kicker">Quick prayer check</span>
              <h3>{prayerCity.name}</h3>
            </div>
            <span class="planner-prayer-next-badge">
              {prayerCityNext.name} · {formatTime(prayerCityNext.time, prayerCity.timezone)}
            </span>
          </div>
          <div class="planner-prayer-row-grid">
            {prayerSchedule.map(p => (
              <div class={`planner-prayer-pill ${prayerCityNext.name === p.name ? 'active' : ''}`}>
                <span class="planner-prayer-pill-name">{p.name}</span>
                <span class="planner-prayer-pill-time">{formatTime(p.time, prayerCity.timezone)}</span>
              </div>
            ))}
          </div>
          <a href={`/prayer-times/${prayerCity.slug}/`} class="feature-link">
            Full schedule for {prayerCity.name}
            <i data-lucide="arrow-right" class="icon-xs"></i>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
