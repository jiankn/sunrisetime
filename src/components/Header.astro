---
/**
 * Header — 浮动导航栏 + 移动端汉堡菜单
 */
import LanguageSwitcher from '@components/LanguageSwitcher.astro';

interface Props {
  languageLinks?: { code: string; label: string; href: string }[];
  currentLanguage?: string;
}

const { languageLinks = [], currentLanguage = 'en' } = Astro.props;
---

<!-- ===== FLOATING NAVBAR ===== -->
<nav class="navbar" id="navbar">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="SunriseTime Home">
      <span class="logo-icon">
        <img src="/logo.svg" alt="SunriseTime Logo" width="28" height="28">
      </span>
      <span class="logo-text">Sunrise<span class="logo-accent">Time</span></span>
    </a>
    <ul class="nav-links" id="navLinks">
      <li><a href="/#search" data-search-city-trigger>Search</a></li>
      <li><a href="/#planner">Plan Your Day</a></li>
      <li><a href="/#cities">Popular Cities</a></li>
      <li><a href="/#faq">FAQ</a></li>
    </ul>
    <div class="nav-actions">
      <a href="/cities/" class="btn-primary-sm">Browse Cities</a>
      <LanguageSwitcher links={languageLinks} currentLanguage={currentLanguage} />
    </div>
    <button class="hamburger" id="hamburger" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="mobileMenu" type="button">
      <i data-lucide="menu" class="icon-sm"></i>
    </button>
  </div>
</nav>

<!-- Mobile Menu Overlay -->
<div class="mobile-menu" id="mobileMenu">
  <ul class="mobile-menu-list">
    <li><a href="/#search" data-search-city-trigger>Search</a></li>
    <li><a href="/#planner">Plan Your Day</a></li>
    <li><a href="/#cities">Popular Cities</a></li>
    <li><a href="/#faq">FAQ</a></li>
  </ul>
  <div class="mobile-menu-section">
    <a href="/cities/" class="btn-primary-sm mobile-menu-cta">Browse Cities</a>
  </div>
  {languageLinks.length > 1 && (
    <div class="mobile-menu-section">
      <LanguageSwitcher links={languageLinks} currentLanguage={currentLanguage} variant="mobile" />
    </div>
  )}
</div>
