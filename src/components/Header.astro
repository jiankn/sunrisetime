---
/**
 * Header — 浮动导航栏 + 移动端汉堡菜单
 */
---

<!-- ===== FLOATING NAVBAR ===== -->
<nav class="navbar" id="navbar">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="SunriseTime Home">
      <span class="logo-icon">
        <img src="/logo.png" alt="SunriseTime Logo" width="28" height="28" style="border-radius:4px;">
      </span>
      <span class="logo-text">Sunrise<span class="logo-accent">Time</span></span>
    </a>
    <ul class="nav-links" id="navLinks">
      <li><a href="/#search">Search</a></li>
      <li><a href="/#planner">Plan Your Day</a></li>
      <li><a href="/#cities">Popular Cities</a></li>
      <li><a href="/#faq">FAQ</a></li>
    </ul>
    <div class="nav-actions">
      <a href="/#search" class="btn-secondary-sm">Search City</a>
      <a href="/cities/" class="btn-primary-sm">Browse Cities</a>
    </div>
    <button class="hamburger" id="hamburger" aria-label="Toggle navigation menu" type="button">
      <i data-lucide="menu" class="icon-sm"></i>
    </button>
  </div>
</nav>

<!-- Mobile Menu Overlay -->
<div class="mobile-menu" id="mobileMenu">
  <ul>
    <li><a href="/#search">Search</a></li>
    <li><a href="/#planner">Plan Your Day</a></li>
    <li><a href="/#cities">Popular Cities</a></li>
    <li><a href="/#faq">FAQ</a></li>
    <li><a href="/#search" class="btn-primary-sm" style="display:inline-block;margin-top:1rem;">Search Your City</a></li>
  </ul>
</div>
