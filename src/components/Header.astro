---
/**
 * Header — 浮动导航栏 + 移动端汉堡菜单
 */
---

<!-- ===== FLOATING NAVBAR ===== -->
<nav class="navbar" id="navbar">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="SunriseTime Home">
      <span class="logo-icon">
        <i data-lucide="sun" class="icon-sm"></i>
      </span>
      <span class="logo-text">Sunrise<span class="logo-accent">Time</span></span>
    </a>
    <ul class="nav-links" id="navLinks">
      <li><a href="/#features">Features</a></li>
      <li><a href="/#dashboard">Dashboard</a></li>
      <li><a href="/#cities">Top Cities</a></li>
      <li><a href="/#faq">FAQ</a></li>
    </ul>
    <div class="nav-actions">
      <a href="/#dashboard" class="btn-secondary-sm">Live Demo</a>
      <a href="/#cities" class="btn-primary-sm">Explore Cities</a>
    </div>
    <button class="hamburger" id="hamburger" aria-label="Toggle navigation menu" type="button">
      <i data-lucide="menu" class="icon-sm"></i>
    </button>
  </div>
</nav>

<!-- Mobile Menu Overlay -->
<div class="mobile-menu" id="mobileMenu">
  <ul>
    <li><a href="/#features">Features</a></li>
    <li><a href="/#dashboard">Dashboard</a></li>
    <li><a href="/#cities">Top Cities</a></li>
    <li><a href="/#faq">FAQ</a></li>
    <li><a href="/#dashboard" class="btn-primary-sm" style="display:inline-block;margin-top:1rem;">Explore Dashboard</a></li>
  </ul>
</div>
