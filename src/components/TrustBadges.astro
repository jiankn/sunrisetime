---
/**
 * Trust Badges — 信任标识
 */
---

<section class="trust-section">
  <div class="container">
    <p class="trust-label">Built for people who need the answer fast and need it to be right</p>
    <div class="trust-badges">
      <div class="trust-badge glass-subtle">
        <i data-lucide="shield-check" class="icon-md"></i>
        <span>NOAA-grade timing</span>
      </div>
      <div class="trust-badge glass-subtle">
        <i data-lucide="globe" class="icon-md"></i>
        <span>5,000+ Cities</span>
      </div>
      <div class="trust-badge glass-subtle">
        <i data-lucide="locate-fixed" class="icon-md"></i>
        <span>Use My Location</span>
      </div>
      <div class="trust-badge glass-subtle">
        <i data-lucide="lock" class="icon-md"></i>
        <span>No Signup</span>
      </div>
      <div class="trust-badge glass-subtle">
        <i data-lucide="camera" class="icon-md"></i>
        <span>Golden Hour Ready</span>
      </div>
    </div>
  </div>
</section>
