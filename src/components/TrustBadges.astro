---
/**
 * Trust Badges — 信任标识
 */
---

<section class="trust-section">
  <div class="container">
    <p class="trust-label">Trusted by photographers, developers, and communities worldwide</p>
    <div class="trust-badges">
      <div class="trust-badge glass-subtle">
        <i data-lucide="shield-check" class="icon-md"></i>
        <span>NOAA Algorithm</span>
      </div>
      <div class="trust-badge glass-subtle">
        <i data-lucide="globe" class="icon-md"></i>
        <span>5,000+ Cities</span>
      </div>
      <div class="trust-badge glass-subtle">
        <i data-lucide="zap" class="icon-md"></i>
        <span>Edge Computing</span>
      </div>
      <div class="trust-badge glass-subtle">
        <i data-lucide="lock" class="icon-md"></i>
        <span>Privacy First</span>
      </div>
      <div class="trust-badge glass-subtle">
        <i data-lucide="clock" class="icon-md"></i>
        <span>Real-Time Data</span>
      </div>
    </div>
  </div>
</section>
