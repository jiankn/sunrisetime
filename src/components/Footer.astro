---
/**
 * Footer - Growth-oriented site footer
 */
import {
  cityIndexLabel,
  featuredFooterCities,
  footerCompanyLinks,
  footerCoreLinks,
  regionHubs,
  totalCities,
  useCaseHubs,
} from '@data/site';
---

<footer class="footer">
  <div class="container">
    <section class="footer-task-panel glass-card-lg">
      <div class="footer-task-grid">
        <div class="footer-task-copy">
          <span class="footer-panel-label">Keep planning</span>
          <h2>Search another city before you leave.</h2>
          <p>The best Footer for SunriseTime is not "about us" first. It is a fast handoff into the next useful city page, region hub, or guide.</p>
          <div class="footer-chip-list">
            {featuredFooterCities.map((city) => (
              <a href={`/sunrise/${city.slug}/`} class="footer-chip">
                {city.name}
              </a>
            ))}
          </div>
        </div>

        <form class="footer-search-panel" data-footer-search>
          <label class="footer-search-shell" for="footerCitySearch">
            <i data-lucide="search" class="icon-sm"></i>
            <input
              id="footerCitySearch"
              type="text"
              data-footer-city-input
              placeholder="Search another city"
              autocomplete="off"
              aria-label="Search another city"
            >
          </label>

          <div class="footer-search-actions">
            <button type="submit" class="btn-primary-sm">Open city page</button>
            <button type="button" class="btn-secondary-sm footer-location-action" data-footer-use-location>
              <i data-lucide="locate-fixed" class="icon-xs"></i>
              <span data-footer-location-label>Use my location</span>
            </button>
          </div>

          <p class="footer-search-status" data-footer-search-status aria-live="polite"></p>
          <p class="footer-search-note">{cityIndexLabel}. Ads help keep the core experience free while the indexed directory grows.</p>
        </form>
      </div>
    </section>
  </div>

  <div class="container footer-grid">
    <div class="footer-brand">
      <div class="nav-logo">
        <span class="logo-icon"><img src="/logo.svg" alt="SunriseTime" width="28" height="28"></span>
        <span class="logo-text">Sunrise<span class="logo-accent">Time</span></span>
      </div>
      <p>Search today&apos;s sunrise, sunset, golden hour, moon phase, and prayer times across {totalCities} indexed cities.</p>
      <p class="footer-brand-note">SunriseTime is designed to answer the first question fast, then route people into the next relevant page instead of sending them back to search from scratch.</p>
    </div>

    <div class="footer-links">
      <h4>Continue Task</h4>
      <ul>
        {footerCoreLinks.map((link) => (
          <li><a href={link.path}>{link.name}</a></li>
        ))}
        <li><a href="/guides/">Guides</a></li>
      </ul>
    </div>

    <div class="footer-links">
      <h4>Browse by Region</h4>
      <ul>
        {regionHubs.map((region) => (
          <li><a href={region.path}>{region.name}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-links">
      <h4>Plan by Use Case</h4>
      <ul>
        {useCaseHubs.map((hub) => (
          <li><a href={hub.path}>{hub.name}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-links">
      <h4>Trust & Support</h4>
      <ul>
        {footerCompanyLinks.map((link) => (
          <li><a href={link.path}>{link.name}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <div class="container footer-bottom">
    <div class="footer-bottom-copy">
      <p>&copy; {new Date().getFullYear()} SunriseTime. {cityIndexLabel}. Built for fast sunrise, sunset, golden hour, moon phase, and prayer-time answers.</p>
      <p class="footer-disclosure">SunriseTime is free to use and may display advertising to support ongoing operation. Review the methodology, privacy policy, and terms before relying on the service for important decisions.</p>
    </div>

    <div class="footer-bottom-links">
      <a href="/methodology/">Methodology</a>
      <a href="/privacy/">Privacy</a>
      <a href="/terms/">Terms</a>
      <a href="/contact/">Contact</a>
      <a href="/sitemap/">Sitemap</a>
    </div>
  </div>
</footer>
