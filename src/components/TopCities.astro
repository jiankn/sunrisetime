---
/**
 * Top Cities — 按大洲分组的城市内链网格
 */
import { regionHubs, totalCities } from '@data/site';

const groups = regionHubs.map((region) => ({
  name: region.name,
  id: `cities-${region.slug}`,
  path: region.path,
  cities: region.cities.slice(0, 6),
}));
---

<section class="top-cities" id="cities">
  <div class="container">
    <div class="section-header">
      <span class="section-badge">
        <i data-lucide="map-pin" class="icon-xs"></i>
        Popular Cities
      </span>
      <h2>Jump straight into today&apos;s light for a city people search most.</h2>
      <p class="section-subtitle">If you do not want to type, use these fast routes to land directly on today&apos;s sunrise, sunset, golden hour, moon, and prayer details.</p>
    </div>

    <div class="cities-grid">
      {groups.map(group => (
        <div class="city-group glass-card" id={group.id}>
          <h3>
            <i data-lucide="globe" class="icon-sm"></i>
            <a href={group.path}>{group.name}</a>
          </h3>
          <ul class="city-list">
            {group.cities.map(city => (
              <li>
                <a href={`/sunrise/${city.slug}/`} class="city-link">
                  <span class="city-name">{city.name}</span>
                  <span class="city-country">{city.country}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="cities-cta">
      <a href="/cities/" class="btn-secondary" id="viewAllCities">
        <i data-lucide="globe" class="icon-xs"></i>
        Browse All {totalCities} Cities
      </a>
    </div>
  </div>
</section>
