---
/**
 * AdUnit — Google AdSense 广告容器
 *
 * 策略：
 * 1. Auto Ads 脚本在 Base layout <head> 中全局引入，Google 自动决定最优广告位置
 * 2. 本组件作为手动 display ad unit 的锚点，提供额外的广告展示机会
 * 3. 无 AdSense pub-id 时渲染为空容器（零视觉干扰）
 *
 * 使用方式：
 * - 替换 data-ad-slot 为你在 AdSense 后台创建的广告单元 ID
 * - 替换 data-ad-client 为你的 AdSense 发布商 ID (ca-pub-XXXXXXXXXXXXXXXX)
 */
interface Props {
  id?: string;
  format?: 'auto' | 'horizontal' | 'vertical' | 'rectangle';
}

const { id, format = 'auto' } = Astro.props;

// 设置为你的 AdSense 发布商 ID，空字符串表示尚未接入
const AD_CLIENT = '';
// 每个广告位对应一个 AdSense 广告单元 ID，接入后替换
const AD_SLOT = '';
---

{AD_CLIENT ? (
  <div class="ad-container" id={id}>
    <div class="container">
      <ins class="adsbygoogle"
        style="display:block"
        data-ad-client={AD_CLIENT}
        data-ad-slot={AD_SLOT}
        data-ad-format={format}
        data-full-width-responsive="true">
      </ins>
      <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </div>
  </div>
) : (
  <!-- Ad slot reserved: configure AD_CLIENT and AD_SLOT to activate -->
  <div class="ad-container" id={id} aria-hidden="true"></div>
)}
