---
/**
 * Hero Section — 搜索优先的首屏快照
 */
import cities from '@data/cities.json';
import { totalCities } from '@data/site';
import { getSunTimes, getGoldenHour, formatTime } from '@utils/sun';
import { getMoonData } from '@utils/moon';
import { getNextPrayer } from '@utils/prayer-times';

type City = typeof cities.cities[0];

const now = new Date();
const previewSlugs = ['new-york', 'london', 'tokyo', 'dubai', 'sydney', 'sao-paulo'];

function getTimezoneLabel(timezone: string) {
  return timezone.split('/').pop()?.replace(/_/g, ' ') ?? timezone;
}

function getNextSunSnapshot(date: Date, city: City) {
  const todaySun = getSunTimes(date, city.lat, city.lng);
  const todayGolden = getGoldenHour(date, city.lat, city.lng);

  if (date < todaySun.sunrise) {
    return {
      label: 'Next sunrise',
      time: formatTime(todaySun.sunrise, city.timezone),
      support: `Morning golden hour ends ${formatTime(todayGolden.morning.end, city.timezone)}`,
    };
  }

  if (date < todaySun.sunset) {
    return {
      label: 'Next sunset',
      time: formatTime(todaySun.sunset, city.timezone),
      support: `Civil dusk lands at ${formatTime(todaySun.dusk, city.timezone)}`,
    };
  }

  const tomorrow = new Date(date);
  tomorrow.setDate(tomorrow.getDate() + 1);
  const tomorrowSun = getSunTimes(tomorrow, city.lat, city.lng);

  return {
    label: 'Tomorrow sunrise',
    time: formatTime(tomorrowSun.sunrise, city.timezone),
    support: `Tomorrow brings ${tomorrowSun.daylightFormatted} of daylight`,
  };
}

const previewCities = previewSlugs
  .map(slug => cities.cities.find(city => city.slug === slug))
  .filter((city): city is City => Boolean(city))
  .map(city => {
    const sun = getSunTimes(now, city.lat, city.lng);
    const golden = getGoldenHour(now, city.lat, city.lng);
    const moon = getMoonData(now, city.lat, city.lng);
    const nextPrayer = getNextPrayer(now, city.lat, city.lng, 'MWL', 'Standard');
    const nextSun = getNextSunSnapshot(now, city);

    return {
      slug: city.slug,
      name: city.name,
      country: city.country,
      timezone: city.timezone,
      caption: `${getTimezoneLabel(city.timezone)} local time · ${now.toLocaleDateString('en-US', {
        weekday: 'short',
        month: 'short',
        day: 'numeric',
        timeZone: city.timezone,
      })}`,
      sunrise: formatTime(sun.sunrise, city.timezone),
      sunset: formatTime(sun.sunset, city.timezone),
      daylight: sun.daylightFormatted,
      golden: `${formatTime(golden.evening.start, city.timezone)} to ${formatTime(golden.evening.end, city.timezone)}`,
      moon: `${moon.phaseName} · ${moon.illumination}%`,
      prayer: `${nextPrayer.name} ${formatTime(nextPrayer.time, city.timezone)}`,
      nextEventLabel: nextSun.label,
      nextEventTime: nextSun.time,
      nextEventSupport: nextSun.support,
    };
  });

const heroCity = previewCities[0];
const searchCities = cities.cities
  .slice()
  .sort((a, b) => b.population - a.population)
  .map(city => ({
    name: city.name,
    slug: city.slug,
    country: city.country,
    lat: city.lat,
    lng: city.lng,
    population: city.population,
  }));
---

<section class="snapshot-hero" id="search">
  <div class="container snapshot-hero-shell">
    <div class="snapshot-hero-copy">
      <div class="hero-badge">
        <i data-lucide="sun-medium" class="icon-xs"></i>
        <span>Search + instant answer</span>
      </div>

      <div class="hero-search-panel glass-card-lg" data-hero-search>
        <div class="hero-search-head">
          <div>
            <span class="hero-search-label">Find today&apos;s answer</span>
            <strong class="hero-search-title">Type a city or jump in from your current location</strong>
          </div>
        </div>
        <div class="hero-search-shell hero-search-shell-lg">
          <i data-lucide="search" class="icon-sm"></i>
          <input
            id="heroCitySearch"
            type="text"
            data-city-search-input
            placeholder="Search a city, e.g. New York, Tokyo, Dubai"
            autocomplete="off"
            aria-autocomplete="list"
            aria-controls="heroSearchResults"
            aria-expanded="false"
            aria-label="Search for a city"
            role="combobox"
          >
          <button type="button" class="hero-location-btn hero-location-btn-inline" data-use-location>
            <i data-lucide="locate-fixed" class="icon-sm"></i>
            <span class="hero-location-text" data-location-label aria-live="polite" aria-atomic="true">Use my location</span>
          </button>
        </div>
        <div class="hero-search-results" id="heroSearchResults" data-search-results role="listbox"></div>

        <div class="hero-quick-row">
          <span class="hero-quick-label">Popular snapshots</span>
          <div class="hero-preview-switches">
            {previewCities.map((city, index) => (
              <button
                type="button"
                class={`hero-city-pill ${index === 0 ? 'active' : ''}`}
                data-hero-city={city.slug}
              >
                {city.name}
              </button>
            ))}
          </div>
        </div>
      </div>

      <div class="hero-search-intro">
        <span class="hero-search-kicker">Built for the first question</span>
        <h1>Search a city. See today&apos;s light at a glance.</h1>
        <p class="hero-subtitle">
          Fast answers for sunrise, sunset, golden hour, moon phase, and prayer timing.
        </p>
      </div>

      <div class="hero-proof-strip">
        <div class="hero-proof-item glass-subtle">
          <strong>{totalCities}</strong>
          <span>cities in the public index</span>
        </div>
        <div class="hero-proof-item glass-subtle">
          <strong>NOAA-grade</strong>
          <span>timing you can trust</span>
        </div>
        <div class="hero-proof-item glass-subtle">
          <strong>No signup</strong>
          <span>straight to the answer</span>
        </div>
      </div>
    </div>

    <div class="hero-snapshot-panel glass-card-lg">
      <div class="hero-panel-top">
        <div>
          <span class="hero-panel-label">Instant answer preview</span>
          <h2>
            <span data-hero-city-name>{heroCity.name}</span>
            <span class="hero-panel-country" data-hero-country>{heroCity.country}</span>
          </h2>
          <p data-hero-caption>{heroCity.caption}</p>
        </div>
        <a class="btn-secondary-sm hero-open-link" data-hero-open href={`/sunrise/${heroCity.slug}/`}>
          <span>Open city page</span>
          <i data-lucide="arrow-up-right" class="icon-sm"></i>
        </a>
      </div>

      <div class="hero-next-card">
        <span class="hero-next-label" data-hero-next-label>{heroCity.nextEventLabel}</span>
        <strong class="hero-next-time" data-hero-next-time>{heroCity.nextEventTime}</strong>
        <span class="hero-next-sub" data-hero-next-support>{heroCity.nextEventSupport}</span>
      </div>

      <div class="hero-mini-grid">
        <div class="hero-mini-card glass-card">
          <span class="hero-mini-label">Sunrise</span>
          <strong data-hero-sunrise>{heroCity.sunrise}</strong>
        </div>
        <div class="hero-mini-card glass-card">
          <span class="hero-mini-label">Sunset</span>
          <strong data-hero-sunset>{heroCity.sunset}</strong>
        </div>
        <div class="hero-mini-card glass-card">
          <span class="hero-mini-label">Daylight</span>
          <strong data-hero-daylight>{heroCity.daylight}</strong>
        </div>
        <div class="hero-mini-card glass-card">
          <span class="hero-mini-label">Golden Hour</span>
          <strong data-hero-golden>{heroCity.golden}</strong>
        </div>
        <div class="hero-mini-card glass-card">
          <span class="hero-mini-label">Moon</span>
          <strong data-hero-moon>{heroCity.moon}</strong>
        </div>
        <div class="hero-mini-card glass-card">
          <span class="hero-mini-label">Next Prayer</span>
          <strong data-hero-prayer>{heroCity.prayer}</strong>
        </div>
      </div>
    </div>
  </div>

  <script type="application/json" id="heroPreviewData" set:html={JSON.stringify(previewCities)} />
  <script type="application/json" id="heroSearchData" set:html={JSON.stringify(searchCities)} />
</section>
