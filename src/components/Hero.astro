---
/**
 * Hero Section — 首屏英雄区
 */
---

<header class="hero" id="hero">
  <div class="hero-bg-effects">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <div class="grid-overlay"></div>
  </div>
  <div class="container hero-content">
    <div class="hero-badge">
      <i data-lucide="zap" class="icon-xs"></i>
      <span>Real-Time Sun & Moon Analytics</span>
    </div>
    <h1>Track Every Sunrise, Sunset &amp; Golden Hour <span class="gradient-text">Worldwide</span></h1>
    <p class="hero-subtitle">SunriseTime delivers precision sunrise and sunset analytics for over 5,000 cities. Real-time dashboards, golden hour tracking, moon phase data, and prayer time calculations — all in one blazing-fast platform powered by edge computing.</p>
    <div class="hero-cta-group">
      <a href="#dashboard" class="btn-primary" id="heroCta">
        <i data-lucide="play" class="icon-xs"></i>
        Explore Dashboard
      </a>
      <a href="#features" class="btn-secondary">
        <i data-lucide="arrow-down" class="icon-xs"></i>
        See Features
      </a>
    </div>
    <div class="hero-stats">
      <div class="stat">
        <span class="stat-value" data-count="5000">0</span>
        <span class="stat-label">Cities Tracked</span>
      </div>
      <div class="stat">
        <span class="stat-value">&lt;50<span class="stat-unit">ms</span></span>
        <span class="stat-label">Response Time</span>
      </div>
      <div class="stat">
        <span class="stat-value">99.9<span class="stat-unit">%</span></span>
        <span class="stat-label">Accuracy</span>
      </div>
      <div class="stat">
        <span class="stat-value">24/7</span>
        <span class="stat-label">Live Updates</span>
      </div>
    </div>
  </div>
  <!-- Hero Dashboard Preview -->
  <div class="container hero-preview">
    <div class="dashboard-preview glass-card">
      <div class="preview-header">
        <div class="preview-dots">
          <span></span><span></span><span></span>
        </div>
        <span class="preview-title">SunriseTime Dashboard — New York City</span>
      </div>
      <div class="preview-grid">
        <div class="preview-card accent-sunrise">
          <div class="preview-card-header">
            <i data-lucide="sunrise" class="icon-sm"></i>
            <span>Sunrise</span>
          </div>
          <span class="preview-value">6:42 AM</span>
          <span class="preview-delta positive">
            <i data-lucide="trending-down" class="icon-xs"></i>
            -1m vs yesterday
          </span>
        </div>
        <div class="preview-card accent-sunset">
          <div class="preview-card-header">
            <i data-lucide="sunset" class="icon-sm"></i>
            <span>Sunset</span>
          </div>
          <span class="preview-value">7:18 PM</span>
          <span class="preview-delta positive">
            <i data-lucide="trending-up" class="icon-xs"></i>
            +2m vs yesterday
          </span>
        </div>
        <div class="preview-card accent-golden">
          <div class="preview-card-header">
            <i data-lucide="camera" class="icon-sm"></i>
            <span>Golden Hour</span>
          </div>
          <span class="preview-value">6:31 PM</span>
          <span class="preview-delta">47 min window</span>
        </div>
        <div class="preview-card accent-moon">
          <div class="preview-card-header">
            <i data-lucide="moon" class="icon-sm"></i>
            <span>Moon Phase</span>
          </div>
          <span class="preview-value">Waxing Gibbous</span>
          <span class="preview-delta">82% illumination</span>
        </div>
      </div>
      <!-- Mini chart area -->
      <div class="preview-chart">
        <div class="chart-label">Daylight Hours — March 2026</div>
        <div class="chart-bars">
          <div class="chart-bar" style="--height:55%"><span>10.2h</span></div>
          <div class="chart-bar" style="--height:60%"><span>10.8h</span></div>
          <div class="chart-bar" style="--height:65%"><span>11.3h</span></div>
          <div class="chart-bar" style="--height:70%"><span>11.8h</span></div>
          <div class="chart-bar active" style="--height:75%"><span>12.3h</span></div>
          <div class="chart-bar" style="--height:80%"><span>12.9h</span></div>
          <div class="chart-bar" style="--height:85%"><span>13.4h</span></div>
        </div>
        <div class="chart-x-labels">
          <span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
        </div>
      </div>
    </div>
  </div>
</header>
