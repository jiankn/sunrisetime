---
import LanguageSwitcher from '@components/LanguageSwitcher.astro';
import { turkishNavigation } from '@i18n/turkish';

interface Props {
  languageLinks?: { code: string; label: string; href: string }[];
  currentLanguage?: string;
}

const { languageLinks = [], currentLanguage = 'tr' } = Astro.props;
---

<nav class="navbar" id="navbar">
  <div class="nav-inner">
    <a href="/tr/" class="nav-logo" aria-label="SunriseTime ana sayfa">
      <span class="logo-icon">
        <img src="/logo.svg" alt="SunriseTime Logo" width="28" height="28">
      </span>
      <span class="logo-text">Sunrise<span class="logo-accent">Time</span></span>
    </a>
    <ul class="nav-links" id="navLinks">
      <li><a href="/tr/#search" data-search-city-trigger>{turkishNavigation.search}</a></li>
      <li><a href="/tr/cities/">{turkishNavigation.cities}</a></li>
      <li><a href="/tr/guides/">{turkishNavigation.guides}</a></li>
      <li><a href="/tr/contact/">{turkishNavigation.contact}</a></li>
    </ul>
    <div class="nav-actions">
      <a href="/tr/cities/" class="btn-primary-sm">{turkishNavigation.browseCities}</a>
      <LanguageSwitcher links={languageLinks} currentLanguage={currentLanguage} ariaLabel="Dil seçici" />
    </div>
    <button class="hamburger" id="hamburger" aria-label="Menüyü aç" aria-expanded="false" aria-controls="mobileMenu" type="button">
      <i data-lucide="menu" class="icon-sm"></i>
    </button>
  </div>
</nav>

<div class="mobile-menu" id="mobileMenu">
  <ul class="mobile-menu-list">
    <li><a href="/tr/#search" data-search-city-trigger>{turkishNavigation.search}</a></li>
    <li><a href="/tr/cities/">{turkishNavigation.cities}</a></li>
    <li><a href="/tr/guides/">{turkishNavigation.guides}</a></li>
    <li><a href="/tr/contact/">{turkishNavigation.contact}</a></li>
  </ul>
  <div class="mobile-menu-section">
    <a href="/tr/cities/" class="btn-primary-sm mobile-menu-cta">{turkishNavigation.browseCities}</a>
  </div>
  {languageLinks.length > 1 && (
    <div class="mobile-menu-section">
      <LanguageSwitcher links={languageLinks} currentLanguage={currentLanguage} ariaLabel="Dil seçici" variant="mobile" />
    </div>
  )}
</div>


