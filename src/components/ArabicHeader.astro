---
import LanguageSwitcher from '@components/LanguageSwitcher.astro';
import { arabicNavigation } from '@i18n/arabic';

interface Props {
  languageLinks?: { code: string; label: string; href: string }[];
  currentLanguage?: string;
}

const { languageLinks = [], currentLanguage = 'ar' } = Astro.props;
---

<nav class="navbar" id="navbar">
  <div class="nav-inner">
    <a href="/ar/" class="nav-logo" aria-label="SunriseTime العربية">
      <span class="logo-icon">
        <img src="/logo.svg" alt="SunriseTime Logo" width="28" height="28">
      </span>
      <span class="logo-text">Sunrise<span class="logo-accent">Time</span></span>
    </a>
    <ul class="nav-links" id="navLinks">
      <li><a href="/ar/#search" data-search-city-trigger>{arabicNavigation.search}</a></li>
      <li><a href="/ar/cities/">{arabicNavigation.cities}</a></li>
      <li><a href="/ar/guides/">{arabicNavigation.guides}</a></li>
      <li><a href="/ar/#faq">{arabicNavigation.faq}</a></li>
    </ul>
    <div class="nav-actions">
      <LanguageSwitcher links={languageLinks} currentLanguage={currentLanguage} />
      <a href="/ar/#search" class="btn-secondary-sm" data-search-city-trigger>{arabicNavigation.searchCity}</a>
      <a href="/ar/cities/" class="btn-primary-sm">{arabicNavigation.browseCities}</a>
    </div>
    <button class="hamburger" id="hamburger" aria-label="فتح القائمة" type="button">
      <i data-lucide="menu" class="icon-sm"></i>
    </button>
  </div>
</nav>

<div class="mobile-menu" id="mobileMenu">
  <ul>
    <li><a href="/ar/#search" data-search-city-trigger>{arabicNavigation.search}</a></li>
    <li><a href="/ar/cities/">{arabicNavigation.cities}</a></li>
    <li><a href="/ar/guides/">{arabicNavigation.guides}</a></li>
    <li><a href="/ar/#faq">{arabicNavigation.faq}</a></li>
    {languageLinks.length > 1 && (
      <li>
        <LanguageSwitcher links={languageLinks} currentLanguage={currentLanguage} />
      </li>
    )}
    <li><a href="/ar/#search" class="btn-primary-sm" style="display:inline-block;margin-top:1rem;" data-search-city-trigger>{arabicNavigation.searchCity}</a></li>
  </ul>
</div>
