---
import LanguageSwitcher from '@components/LanguageSwitcher.astro';
import { chineseNavigation } from '@i18n/chinese';

interface Props {
  languageLinks?: { code: string; label: string; href: string }[];
  currentLanguage?: string;
}

const { languageLinks = [], currentLanguage = 'zh-cn' } = Astro.props;
---

<nav class="navbar" id="navbar">
  <div class="nav-inner">
    <a href="/zh-cn/" class="nav-logo" aria-label="SunriseTime 简体中文版">
      <span class="logo-icon">
        <img src="/logo.svg" alt="SunriseTime 标志" width="28" height="28">
      </span>
      <span class="logo-text">Sunrise<span class="logo-accent">Time</span></span>
    </a>
    <ul class="nav-links" id="navLinks">
      <li><a href="/zh-cn/#search" data-search-city-trigger>{chineseNavigation.search}</a></li>
      <li><a href="/zh-cn/cities/">{chineseNavigation.cities}</a></li>
      <li><a href="/zh-cn/guides/">{chineseNavigation.guides}</a></li>
      <li><a href="/zh-cn/contact/">{chineseNavigation.contact}</a></li>
    </ul>
    <div class="nav-actions">
      <a href="/zh-cn/cities/" class="btn-primary-sm">{chineseNavigation.browseCities}</a>
      <LanguageSwitcher links={languageLinks} currentLanguage={currentLanguage} ariaLabel="语言切换" />
    </div>
    <button class="hamburger" id="hamburger" aria-label="打开菜单" aria-expanded="false" aria-controls="mobileMenu" type="button">
      <i data-lucide="menu" class="icon-sm"></i>
    </button>
  </div>
</nav>

<div class="mobile-menu" id="mobileMenu">
  <ul class="mobile-menu-list">
    <li><a href="/zh-cn/#search" data-search-city-trigger>{chineseNavigation.search}</a></li>
    <li><a href="/zh-cn/cities/">{chineseNavigation.cities}</a></li>
    <li><a href="/zh-cn/guides/">{chineseNavigation.guides}</a></li>
    <li><a href="/zh-cn/contact/">{chineseNavigation.contact}</a></li>
  </ul>
  <div class="mobile-menu-section">
    <a href="/zh-cn/cities/" class="btn-primary-sm mobile-menu-cta">{chineseNavigation.browseCities}</a>
  </div>
  {languageLinks.length > 1 && (
    <div class="mobile-menu-section">
      <LanguageSwitcher links={languageLinks} currentLanguage={currentLanguage} ariaLabel="语言切换" variant="mobile" />
    </div>
  )}
</div>
